<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <!--
    Cada <Files> lleva un Subdirectory unico por feature para forzar
    que el harvester de WiX 4 sintetice distintos directoryIds en
    el auto-id (fls|SHA1(directoryId|filename)|). Sin esto, WiX 4
    calcula el mismo directoryId para ambos harvests y cualquier
    archivo con nombre comun (appsettings.json, PolyglotCLI.core.dll,
    etc.) choca como WIX0091 Duplicate File.

    Como consecuencia los ejecutables quedan en:
      INSTALLFOLDER/Server/serverapp/PolyglotCLI.exe
      INSTALLFOLDER/Desktop/desktopapp/PolyglotCLI.Maui.exe

    Los accesos directos en Shortcuts.wxs apuntan a esas subcarpetas.
  -->
  <Fragment>
    <!-- Archivos del Servidor Web (PolyglotCLI.web) en Server/serverapp/ -->
    <ComponentGroup Id="ServerComponents" Directory="ServerFolder">
      <Files Include="..\publish_out\**" Subdirectory="serverapp" Directory="ServerFolder" />
    </ComponentGroup>
  </Fragment>

  <Fragment>
    <!-- Archivos de la Aplicacion de Escritorio (PolyglotCLI.Maui) en Desktop/desktopapp/ -->
    <ComponentGroup Id="DesktopComponents" Directory="DesktopFolder_App">
      <Files Include="..\publish_maui\**" Subdirectory="desktopapp" Directory="DesktopFolder_App" />
    </ComponentGroup>
  </Fragment>
</Wix>
