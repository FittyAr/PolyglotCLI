<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <!--
    Cada <Files> se compila en su propio <Fragment> para evitar el bug
    WIX0091 del harvester de WiX 4, que con dos <Files> hermanos bajo
    el mismo padre sintetiza el mismo directoryId (INSTALLFOLDER) y
    provoca colisiones de File.Id para archivos de mismo nombre
    (appsettings.json, *.dll compartido de PolyglotCLI.core, etc.).
    Se añade ademas Directory="..." explicito en cada <Files> como
    salvaguarda extra para forzar el contexto de subdirectorio en
    la generacion del auto-id.
  -->
  <Fragment>
    <!-- Archivos del Servidor Web (PolyglotCLI.web) instalados en Server/ -->
    <ComponentGroup Id="ServerComponents" Directory="ServerFolder">
      <Files Include="..\publish_out\**" Directory="ServerFolder" />
    </ComponentGroup>
  </Fragment>

  <Fragment>
    <!-- Archivos de la Aplicacion de Escritorio (PolyglotCLI.Maui) instalados en Desktop/ -->
    <ComponentGroup Id="DesktopComponents" Directory="DesktopFolder_App">
      <Files Include="..\publish_maui\**" Directory="DesktopFolder_App" />
    </ComponentGroup>
  </Fragment>
</Wix>
