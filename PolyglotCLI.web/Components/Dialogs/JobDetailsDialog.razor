@using PolyglotCLI
@using System.IO
@using System.Linq
@using System.Collections.Generic
@inject DialogService DialogService
@inject NotificationService NotificationService
@inject PolyglotCLI.AppConfig Config

<RadzenCard class="rz-mb-4" Style="background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.08);">
    <RadzenRow Gap="1rem">
        <RadzenColumn Size="3">
            <RadzenText TextStyle="TextStyle.Caption" style="color: #b0bec5;">Creado el</RadzenText>
            <RadzenText TextStyle="TextStyle.Body2" style="font-weight: bold;">@Job.CreatedAt.ToString("d/M/yyyy HH:mm")</RadzenText>
        </RadzenColumn>
        <RadzenColumn Size="3">
            <RadzenText TextStyle="TextStyle.Caption" style="color: #b0bec5;">Idioma Destino</RadzenText>
            <RadzenText TextStyle="TextStyle.Body2" style="font-weight: bold;">@Job.TargetLanguage</RadzenText>
        </RadzenColumn>
        <RadzenColumn Size="3">
            <RadzenText TextStyle="TextStyle.Caption" style="color: #b0bec5;">Modelo LLM</RadzenText>
            <RadzenText TextStyle="TextStyle.Body2" style="font-weight: bold;">@(!string.IsNullOrEmpty(Job.ModelName) ? Job.ModelName : "Defecto del Servidor")</RadzenText>
        </RadzenColumn>
        <RadzenColumn Size="3">
            <RadzenText TextStyle="TextStyle.Caption" style="color: #b0bec5;">Estado General</RadzenText>
            <div>
                <RadzenBadge BadgeStyle="@GetBadgeStyle(Job.Status)" Text="@Job.Status" />
            </div>
        </RadzenColumn>
    </RadzenRow>
</RadzenCard>

<RadzenTabs RenderMode="TabRenderMode.Client" class="rz-m-0">
    <Tabs>
        <RadzenTabsItem Text="Resumen y Progreso" Icon="assignment">
            <RadzenText TextStyle="TextStyle.Subtitle1" class="rz-my-3" style="font-weight: bold;">Archivos del Trabajo</RadzenText>
            
            <RadzenDataGrid Data="@Job.Files" TItem="JobFileManifest" AllowPaging="true" PageSize="5" class="rz-mb-4">
                <Template Context="file">
                    <RadzenCard Style="padding: 1rem; background: rgba(255, 255, 255, 0.02); border: 1px solid rgba(255, 255, 255, 0.05);">
                        <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-mb-2" style="font-weight: bold;">Progreso por Página / Fragmento</RadzenText>
                        @if(file.Pages != null && file.Pages.Count > 0)
                        {
                            <RadzenDataGrid Data="@file.Pages" TItem="JobPageManifest" AllowPaging="false" AllowSorting="false">
                                <Columns>
                                    <RadzenDataGridColumn TItem="JobPageManifest" Property="PageNumber" Title="Pág/Chunk" Width="90px" TextAlign="TextAlign.Center" />
                                    
                                    <RadzenDataGridColumn TItem="JobPageManifest" Title="Extracción / OCR" Width="180px">
                                        <Template Context="pageItem">
                                            @if(pageItem.OcrCompleted)
                                            {
                                                <span style="color: #4caf50; display: inline-flex; align-items: center; gap: 4px;">
                                                    <RadzenIcon Icon="check_circle" Style="color: #4caf50; font-size: 1.1rem; vertical-align: middle;" /> Completado
                                                </span>
                                            }
                                            else if(!string.IsNullOrEmpty(pageItem.OcrError))
                                            {
                                                <span style="color: #f44336; display: inline-flex; align-items: center; gap: 4px;" title="@pageItem.OcrError">
                                                    <RadzenIcon Icon="error" Style="color: #f44336; font-size: 1.1rem; vertical-align: middle;" /> Falló
                                                </span>
                                            }
                                            else
                                            {
                                                <span style="color: #ffb74d; display: inline-flex; align-items: center; gap: 4px;">
                                                    <RadzenIcon Icon="hourglass_empty" Style="color: #ffb74d; font-size: 1.1rem; vertical-align: middle;" /> Pendiente
                                                </span>
                                            }
                                        </Template>
                                    </RadzenDataGridColumn>

                                    <RadzenDataGridColumn TItem="JobPageManifest" Title="Traducción" Width="180px">
                                        <Template Context="pageItem">
                                            @if(pageItem.TranslationCompleted)
                                            {
                                                <span style="color: #4caf50; display: inline-flex; align-items: center; gap: 4px;">
                                                    <RadzenIcon Icon="check_circle" Style="color: #4caf50; font-size: 1.1rem; vertical-align: middle;" /> Completado
                                                </span>
                                            }
                                            else if(!string.IsNullOrEmpty(pageItem.TranslationError))
                                            {
                                                <span style="color: #f44336; display: inline-flex; align-items: center; gap: 4px;" title="@pageItem.TranslationError">
                                                    <RadzenIcon Icon="error" Style="color: #f44336; font-size: 1.1rem; vertical-align: middle;" /> Falló
                                                </span>
                                            }
                                            else
                                            {
                                                <span style="color: #ffb74d; display: inline-flex; align-items: center; gap: 4px;">
                                                    <RadzenIcon Icon="hourglass_empty" Style="color: #ffb74d; font-size: 1.1rem; vertical-align: middle;" /> Pendiente
                                                </span>
                                            }
                                        </Template>
                                    </RadzenDataGridColumn>

                                    <RadzenDataGridColumn TItem="JobPageManifest" Title="Revisión" Width="180px">
                                        <Template Context="pageItem">
                                            @if(pageItem.ReviewCompleted)
                                            {
                                                <span style="color: #4caf50; display: inline-flex; align-items: center; gap: 4px;">
                                                    <RadzenIcon Icon="check_circle" Style="color: #4caf50; font-size: 1.1rem; vertical-align: middle;" /> Completado
                                                </span>
                                            }
                                            else if(!string.IsNullOrEmpty(pageItem.ReviewError))
                                            {
                                                <span style="color: #f44336; display: inline-flex; align-items: center; gap: 4px;" title="@pageItem.ReviewError">
                                                    <RadzenIcon Icon="error" Style="color: #f44336; font-size: 1.1rem; vertical-align: middle;" /> Falló
                                                </span>
                                            }
                                            else
                                            {
                                                <span style="color: #ffb74d; display: inline-flex; align-items: center; gap: 4px;">
                                                    <RadzenIcon Icon="hourglass_empty" Style="color: #ffb74d; font-size: 1.1rem; vertical-align: middle;" /> Pendiente/No req.
                                                </span>
                                            }
                                        </Template>
                                    </RadzenDataGridColumn>

                                    <RadzenDataGridColumn TItem="JobPageManifest" Title="Conversión Doc" Width="180px">
                                        <Template Context="pageItem">
                                            <span style="@(pageItem.ConversionCompleted ? "color: #4caf50;" : "color: #b0bec5;") display: inline-flex; align-items: center; gap: 4px;">
                                                <RadzenIcon Icon="@(pageItem.ConversionCompleted ? "check_circle" : "help_outline")" Style="@((pageItem.ConversionCompleted ? "color: #4caf50;" : "color: #b0bec5;") + " font-size: 1.1rem; vertical-align: middle;")" />
                                                @(pageItem.ConversionCompleted ? "Completado" : "Pendiente/No req.")
                                            </span>
                                        </Template>
                                    </RadzenDataGridColumn>
                                </Columns>
                            </RadzenDataGrid>
                        }
                        else
                        {
                            <span style="color: #b0bec5;">No hay páginas o fragmentos registrados aún para este archivo.</span>
                        }
                    </RadzenCard>
                </Template>
                <Columns>
                    <RadzenDataGridColumn TItem="JobFileManifest" Property="OriginalFileName" Title="Nombre del Archivo Original" />
                    <RadzenDataGridColumn TItem="JobFileManifest" Property="Completed" Title="Estado del Archivo" Width="130px" TextAlign="TextAlign.Center">
                        <Template Context="file">
                            <RadzenBadge BadgeStyle="@(file.Completed ? BadgeStyle.Success : BadgeStyle.Danger)" Text="@(file.Completed ? "Completado" : "Incompleto")" />
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="JobFileManifest" Property="Pages.Count" Title="Pág/Chunks Totales" Width="160px" TextAlign="TextAlign.Center" />
                </Columns>
            </RadzenDataGrid>
        </RadzenTabsItem>

        <RadzenTabsItem Text="Verificador de Páginas " Icon="find_in_page">
            <RadzenRow class="rz-mt-3">
                <RadzenColumn Size="3">
                    <RadzenCard style="height: calc(92vh - 220px); background: rgba(0,0,0,0.15); display: flex; flex-direction: column; gap: 12px;">
                        <RadzenText TextStyle="TextStyle.Subtitle2" style="font-weight: bold;">1. Selecciona Documento</RadzenText>
                        <RadzenDropDown Data="@jsonDataFiles" TValue="string" Value="@selectedJsonFile" Change="@((args) => OnSelectJsonFile((string)args))" Placeholder="Selecciona archivo JSON..." class="rz-w-100" />
                        
                        @if (pageDataList != null && pageDataList.Count > 0)
                        {
                            <RadzenText TextStyle="TextStyle.Subtitle2" style="font-weight: bold; margin-top: 8px;">2. Selecciona Página</RadzenText>
                            <RadzenListBox Data="@pageDataList" TValue="DocumentPageData" Value="@selectedPageData" Change="@((args) => OnSelectPage((DocumentPageData)args))" style="flex-grow: 1; height: calc(92vh - 310px); background: transparent; border: 1px solid rgba(255,255,255,0.08);">
                                <Template Context="p">
                                    <div style="display: flex; align-items: center; justify-content: space-between; width: 100%;">
                                        <span>Pág / Chunk @p.PageNumber</span>
                                        <div style="display: flex; gap: 4px;">
                                            <RadzenIcon Icon="@(p.IsOcrSuccessful ? "check_circle" : "error")" Style="@(p.IsOcrSuccessful ? "color: #10b981; font-size: 1rem;" : "color: #ef4444; font-size: 1rem;")" />
                                            <RadzenIcon Icon="@(p.IsTranslationSuccessful ? "check_circle" : "error")" Style="@(p.IsTranslationSuccessful ? "color: #10b981; font-size: 1rem;" : "color: #ef4444; font-size: 1rem;")" />
                                        </div>
                                    </div>
                                </Template>
                            </RadzenListBox>
                        }
                    </RadzenCard>
                </RadzenColumn>
                <RadzenColumn Size="9">
                    <RadzenCard style="height: calc(92vh - 220px); background: rgba(0,0,0,0.15); display: flex; flex-direction: column;">
                        @if (selectedPageData != null)
                        {
                            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
                                <RadzenText TextStyle="TextStyle.Subtitle1" style="font-weight: bold; margin: 0;">
                                    Visualizando Página @selectedPageData.PageNumber de @(pageDataList?.Count ?? 0)
                                </RadzenText>
                                <RadzenButton Text="Re-procesar esta página" Icon="autorenew" ButtonStyle="ButtonStyle.Warning" Size="ButtonSize.Small" Click="@(() => ReprocessPage())" IsBusy="@isReprocessingPage" BusyText="Procesando..." />
                            </div>
                            
                            <RadzenRow Gap="1rem" style="flex-grow: 1;">
                                <RadzenColumn Size="6" style="display: flex; flex-direction: column;">
                                    <RadzenTabs RenderMode="TabRenderMode.Client" style="flex-grow: 1; display: flex; flex-direction: column; height: calc(92vh - 310px);">
                                        <Tabs>
                                            <RadzenTabsItem Text="Original (PDF / Imagen)" Icon="image">
                                                <div style="height: calc(92vh - 390px); display: flex; flex-direction: column; margin-top: 8px; border: 1px solid rgba(255,255,255,0.08); border-radius: 4px; overflow: auto; background: #000; justify-content: center; align-items: center;">
                                                    @if (hasPageImage && !string.IsNullOrEmpty(pageImageBase64))
                                                    {
                                                        <div style="flex-grow: 1; display: flex; justify-content: center; align-items: center; padding: 8px;">
                                                            <img src="data:image/png;base64,@pageImageBase64" style="max-width: 100%; max-height: calc(92vh - 410px); object-fit: contain;" />
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <div style="display: flex; align-items: center; justify-content: center; height: 100%; color: #b0bec5; font-size: 0.9rem; padding: 12px; text-align: center;">
                                                            No hay imagen renderizada disponible para este tipo de documento.
                                                        </div>
                                                    }
                                                </div>
                                            </RadzenTabsItem>
                                            <RadzenTabsItem Text="Texto Extraído (OCR)" Icon="description">
                                                <div style="height: calc(92vh - 390px); display: flex; flex-direction: column; margin-top: 8px;">
                                                    <pre style="flex-grow: 1; margin: 0; padding: 12px; font-family: monospace; font-size: 0.9rem; color: #94a3b8; white-space: pre-wrap; background: #0f172a; border: 1px solid rgba(255,255,255,0.08); border-radius: 4px; height: 100%; overflow-y: auto;">@selectedPageData.OriginalText</pre>
                                                </div>
                                            </RadzenTabsItem>
                                        </Tabs>
                                    </RadzenTabs>
                                </RadzenColumn>
                                <RadzenColumn Size="6" style="display: flex; flex-direction: column;">
                                    <RadzenTabs RenderMode="TabRenderMode.Client" style="flex-grow: 1; display: flex; flex-direction: column; height: calc(92vh - 310px);">
                                        <Tabs>
                                            <RadzenTabsItem Text="Traducción" Icon="translate">
                                                <div style="height: calc(92vh - 390px); display: flex; flex-direction: column; margin-top: 8px;">
                                                    <RadzenTextArea @bind-Value="selectedPageData.TranslatedText" style="flex-grow: 1; font-family: monospace; font-size: 0.9rem; background: #0f172a; color: #cbd5e1; border: 1px solid rgba(255,255,255,0.08); padding: 12px; border-radius: 4px; resize: none; height: 100%;" Change="@OnTranslationEdited" />
                                                </div>
                                            </RadzenTabsItem>
                                            <RadzenTabsItem Text="Pensamiento (Reasoning)" Icon="psychology">
                                                <div style="height: calc(92vh - 390px); display: flex; flex-direction: column; margin-top: 8px;">
                                                    @if (!string.IsNullOrEmpty(selectedPageData.ThoughtText))
                                                    {
                                                        <pre style="flex-grow: 1; margin: 0; padding: 12px; font-family: monospace; font-size: 0.9rem; color: #f59e0b; white-space: pre-wrap; background: #0b0f19; border: 1px solid rgba(255,255,255,0.08); border-radius: 4px; height: 100%; overflow-y: auto;">@selectedPageData.ThoughtText</pre>
                                                    }
                                                    else
                                                    {
                                                        <div style="display: flex; align-items: center; justify-content: center; height: 100%; color: #b0bec5; font-size: 0.9rem; border: 1px solid rgba(255,255,255,0.08); border-radius: 4px; background: #0b0f19;">
                                                            No hay trazas de razonamiento (&lt;think&gt;) disponibles para esta página.
                                                        </div>
                                                    }
                                                </div>
                                            </RadzenTabsItem>
                                        </Tabs>
                                    </RadzenTabs>
                                </RadzenColumn>
                            </RadzenRow>
                        }
                        else
                        {
                            <div style="display: flex; align-items: center; justify-content: center; height: calc(92vh - 310px); color: #b0bec5; flex-direction: column; gap: 8px;">
                                <RadzenIcon Icon="find_in_page" Style="font-size: 3rem; color: #6366f1;" />
                                <span>Selecciona un documento y una página del panel izquierdo para comenzar el análisis visual.</span>
                            </div>
                        }
                    </RadzenCard>
                </RadzenColumn>
            </RadzenRow>
        </RadzenTabsItem>

        <RadzenTabsItem Text="Archivos Generados (.md / .docx)" Icon="folder_open">
            <RadzenRow class="rz-mt-3">
                <RadzenColumn Size="4">
                    <RadzenCard style="height: calc(92vh - 220px); overflow-y: auto; background: rgba(0,0,0,0.15);">
                        <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-mb-2" style="font-weight: bold;">Archivos en el Directorio de Salida</RadzenText>
                        @if (outputFiles.Count == 0)
                        {
                            <div style="padding: 10px; color: #b0bec5; font-size: 0.9rem;">No se encontraron archivos en la carpeta de salida del trabajo.</div>
                        }
                        else
                        {
                            <RadzenListBox Data="@outputFiles" TValue="string" style="width: 100%; height: calc(92vh - 310px); background: transparent; border: none;" Change="@((args) => SelectOutputFile((string)args))">
                                <Template Context="path">
                                    <div style="display: flex; align-items: center; gap: 8px;">
                                        <RadzenIcon Icon="@(path.EndsWith(".md", StringComparison.OrdinalIgnoreCase) ? "article" : "description")" Style="font-size: 1.2rem; color: #6366f1;" />
                                        <span>@Path.GetFileName(path)</span>
                                    </div>
                                </Template>
                            </RadzenListBox>
                        }
                    </RadzenCard>
                </RadzenColumn>
                <RadzenColumn Size="8">
                    <RadzenCard style="height: calc(92vh - 220px); display: flex; flex-direction: column; background: rgba(0,0,0,0.15);">
                        <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-mb-2" style="font-weight: bold;">
                            Previsualización: @(selectedOutputFileName ?? "Selecciona un archivo")
                        </RadzenText>
                        @if (selectedOutputFileContent != null)
                        {
                            <div class="virtual-console flex-grow-1" style="height: calc(92vh - 270px); overflow-y: auto; white-space: pre-wrap; background-color: #030712; color: #cbd5e1; font-family: monospace; padding: 12px; border-radius: 6px;">@selectedOutputFileContent</div>
                        }
                        else
                        {
                            <div style="display: flex; align-items: center; justify-content: center; height: calc(92vh - 270px); color: #b0bec5;">
                                Selecciona un archivo de texto/markdown de la lista para ver su contenido.
                            </div>
                        }
                    </RadzenCard>
                </RadzenColumn>
            </RadzenRow>
        </RadzenTabsItem>

        <RadzenTabsItem Text="Imágenes Extraídas (PDF)" Icon="image">
            <RadzenRow class="rz-mt-3">
                <RadzenColumn Size="2">
                    <RadzenCard style="height: calc(92vh - 220px); overflow-y: auto; background: rgba(0,0,0,0.15); padding: 8px;">
                        <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-mb-2" style="font-weight: bold; font-size: 0.9rem;">Páginas (PNG)</RadzenText>
                        @if (tempImages.Count == 0)
                        {
                            <div style="padding: 10px; color: #b0bec5; font-size: 0.8rem;">No se encontraron imágenes.</div>
                        }
                        else
                        {
                            <RadzenListBox Data="@tempImages" TValue="string" style="width: 100%; height: calc(92vh - 310px); background: transparent; border: none; font-size: 0.8rem;" Change="@((args) => SelectImage((string)args))">
                                <Template Context="path">
                                    <div style="display: flex; align-items: center; gap: 4px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                        <RadzenIcon Icon="image" Style="font-size: 1rem; color: #10b981; min-width: 16px;" />
                                        <span title="@Path.GetFileName(path)">@Path.GetFileName(path)</span>
                                    </div>
                                </Template>
                            </RadzenListBox>
                        }
                    </RadzenCard>
                </RadzenColumn>
                <RadzenColumn Size="10">
                    <RadzenCard style="height: calc(92vh - 220px); display: flex; flex-direction: column; background: rgba(0,0,0,0.15);">
                        <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-mb-2" style="font-weight: bold; width: 100%;">
                            Visor: @(selectedImageName ?? "Selecciona una página")
                        </RadzenText>
                        @if (selectedImageBase64 != null)
                        {
                            <div style="height: calc(92vh - 310px); width: 100%; overflow: auto; border: 1px solid rgba(255,255,255,0.05); padding: 8px; border-radius: 4px; background: #000; display: block; text-align: center;">
                                <img src="data:image/png;base64,@selectedImageBase64" style="width: 100%; height: auto; display: block; margin: 0 auto;" />
                            </div>
                        }
                        else
                        {
                            <div style="display: flex; align-items: center; justify-content: center; height: calc(92vh - 330px); color: #b0bec5;">
                                Selecciona una página de la lista para visualizar la imagen renderizada del PDF.
                            </div>
                        }
                    </RadzenCard>
                </RadzenColumn>
            </RadzenRow>
        </RadzenTabsItem>

        <RadzenTabsItem Text="Bitácora de Logs" Icon="article">
            <RadzenRow class="rz-mt-3">
                <RadzenColumn Size="4">
                    <RadzenCard style="height: calc(92vh - 220px); overflow-y: auto; background: rgba(0,0,0,0.15);">
                        <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-mb-2" style="font-weight: bold;">Archivos de Bitácora</RadzenText>
                        @if (logFiles.Count == 0)
                        {
                            <div style="padding: 10px; color: #b0bec5; font-size: 0.9rem;">No se encontraron archivos de log en este trabajo.</div>
                        }
                        else
                        {
                            <RadzenListBox Data="@logFiles" TValue="string" style="width: 100%; height: calc(92vh - 310px); background: transparent; border: none;" Change="@((args) => SelectLogFile((string)args))">
                                <Template Context="path">
                                    <div style="display: flex; align-items: center; gap: 8px;">
                                        <RadzenIcon Icon="receipt_long" Style="font-size: 1.2rem; color: #f59e0b;" />
                                        <span>@Path.GetFileName(path)</span>
                                    </div>
                                </Template>
                            </RadzenListBox>
                        }
                    </RadzenCard>
                </RadzenColumn>
                <RadzenColumn Size="8">
                    <RadzenCard style="height: calc(92vh - 220px); display: flex; flex-direction: column; background: rgba(0,0,0,0.15);">
                        <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-mb-2" style="font-weight: bold;">
                            Contenido: @(selectedLogFileName ?? "Selecciona un log")
                        </RadzenText>
                        @if (selectedLogFileContent != null)
                        {
                            <div class="virtual-console flex-grow-1" style="height: calc(92vh - 270px); overflow-y: auto; white-space: pre-wrap; background-color: #030712; color: #f59e0b; font-family: monospace; padding: 12px; border-radius: 6px;">@selectedLogFileContent</div>
                        }
                        else
                        {
                            <div style="display: flex; align-items: center; justify-content: center; height: calc(92vh - 270px); color: #b0bec5;">
                                Selecciona una bitácora para previsualizar los eventos registrados en el backend.
                            </div>
                        }
                    </RadzenCard>
                </RadzenColumn>
            </RadzenRow>
        </RadzenTabsItem>
    </Tabs>
</RadzenTabs>

<div class="rz-text-align-right rz-mt-4">
    <RadzenButton Text="Cerrar" Click="@(() => DialogService.Close())" ButtonStyle="ButtonStyle.Secondary" />
</div>

@code {
    [Parameter]
    public JobManifest Job { get; set; } = default!;

    private string jobDir => Path.Combine(TranslationOrchestrator.GetJobsDirectory(), Job.JobId);

    private List<string> outputFiles = new List<string>();
    private string? selectedOutputFileContent = null;
    private string? selectedOutputFileName = null;

    private List<string> tempImages = new List<string>();
    private string? selectedImageBase64 = null;
    private string? selectedImageName = null;

    private List<string> logFiles = new List<string>();
    private string? selectedLogFileContent = null;
    private string? selectedLogFileName = null;

    // Verificador de páginas variables
    private List<string> jsonDataFiles = new List<string>();
    private string? selectedJsonFile = null;
    private List<DocumentPageData> pageDataList = new List<DocumentPageData>();
    private DocumentPageData? selectedPageData = null;
    private bool hasPageImage = false;
    private string? pageImageBase64 = null;
    private bool isReprocessingPage = false;

    protected override void OnInitialized()
    {
        LoadOutputFiles();
        LoadTempImages();
        LoadLogFiles();
        LoadJsonDataFiles();
    }

    private void LoadJsonDataFiles()
    {
        try
        {
            string dataPath = Path.Combine(jobDir, "data");
            if (Directory.Exists(dataPath))
            {
                jsonDataFiles = Directory.GetFiles(dataPath, "*_data.json")
                    .Select(Path.GetFileName)
                    .Where(n => n != null)
                    .Select(n => n!)
                    .ToList();
            }
        }
        catch {}
    }

    private void OnSelectJsonFile(string file)
    {
        selectedJsonFile = file;
        selectedPageData = null;
        pageImageBase64 = null;
        hasPageImage = false;
        
        try
        {
            string filePath = Path.Combine(jobDir, "data", file);
            if (File.Exists(filePath))
            {
                string jsonStr = File.ReadAllText(filePath);
                pageDataList = System.Text.Json.JsonSerializer.Deserialize<List<DocumentPageData>>(jsonStr) ?? new List<DocumentPageData>();
                if (pageDataList.Count > 0)
                {
                    OnSelectPage(pageDataList[0]);
                }
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Summary = "Error al cargar páginas", Detail = ex.Message });
        }
    }

    private void OnSelectPage(DocumentPageData p)
    {
        selectedPageData = p;
        pageImageBase64 = null;
        hasPageImage = false;

        if (selectedPageData == null || string.IsNullOrEmpty(selectedJsonFile)) return;

        try
        {
            string docName = selectedJsonFile.Replace("_data.json", "");
            string tempPath = Path.Combine(jobDir, "temp");
            
            string pngPath = Path.Combine(tempPath, $"{docName}_page_{p.PageNumber}.png");
            if (File.Exists(pngPath))
            {
                byte[] bytes = File.ReadAllBytes(pngPath);
                pageImageBase64 = Convert.ToBase64String(bytes);
                hasPageImage = true;
            }
        }
        catch {}
    }

    private async Task OnTranslationEdited(string newText)
    {
        if (selectedPageData == null || string.IsNullOrEmpty(selectedJsonFile)) return;

        try
        {
            string filePath = Path.Combine(jobDir, "data", selectedJsonFile);
            if (File.Exists(filePath))
            {
                selectedPageData.TranslatedText = newText;
                
                var states = pageDataList.Select(d => new PageProcessState
                {
                    PageNumber = d.PageNumber,
                    OcrText = d.OriginalText,
                    TranslatedText = d.TranslatedText,
                    ReviewedText = d.ReviewedText,
                    OcrFailed = !d.IsOcrSuccessful,
                    TranslationFailed = !d.IsTranslationSuccessful,
                    OcrErrorMessage = d.OcrErrorMessage,
                    TranslationErrorMessage = d.TranslationErrorMessage,
                    ThoughtText = d.ThoughtText
                }).ToList();
                
                JobManifestService.SavePageStatesToJson(states, filePath);
                
                string sourceFileName = selectedJsonFile.Replace("_data.json", "");
                var fileManifest = Job.Files.Find(f => Path.GetFileNameWithoutExtension(f.SourceFilePath).Equals(sourceFileName, StringComparison.OrdinalIgnoreCase));
                if (fileManifest != null)
                {
                    string absoluteOutputDir = Path.GetFullPath(Config.OutputDirectory);
                    string outputPath = Path.Combine(absoluteOutputDir, $"{sourceFileName}_{Config.TargetLanguage}.md");
                    MarkdownWriter.ExportToMarkdown(outputPath, sourceFileName, Config.TargetLanguage, pageDataList, false);

                    string outputsDir = Path.Combine(jobDir, "outputs");
                    if (!Directory.Exists(outputsDir)) Directory.CreateDirectory(outputsDir);
                    File.Copy(outputPath, Path.Combine(outputsDir, Path.GetFileName(outputPath)), true);

                    if (!string.IsNullOrEmpty(Config.DefaultOutputFormat) && Config.ModuleConversionEnabled)
                    {
                        await OutputFormatConverter.ConvertToFormatsAsync(outputPath, Config.DefaultOutputFormat);
                    }
                }
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Summary = "Error al guardar cambios", Detail = ex.Message });
        }
    }

    private async Task ReprocessPage()
    {
        if (selectedPageData == null || string.IsNullOrEmpty(selectedJsonFile)) return;

        isReprocessingPage = true;
        StateHasChanged();

        try
        {
            string sourceFileName = selectedJsonFile.Replace("_data.json", "");
            var fileManifest = Job.Files.Find(f => Path.GetFileNameWithoutExtension(f.SourceFilePath).Equals(sourceFileName, StringComparison.OrdinalIgnoreCase));
            
            if (fileManifest == null)
            {
                NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Summary = "Reprocesamiento", Detail = "No se pudo asociar el archivo de datos con el archivo de origen." });
                return;
            }

            bool success = await Task.Run(() => TranslationOrchestrator.ReprocessPageAsync(
                Job.JobId, 
                fileManifest.SourceFilePath, 
                selectedPageData.PageNumber, 
                Config
            ));

            if (success)
            {
                NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Success, Summary = "Reprocesamiento", Detail = $"Página {selectedPageData.PageNumber} procesada con éxito." });
                OnSelectJsonFile(selectedJsonFile);
            }
            else
            {
                NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Summary = "Reprocesamiento", Detail = "El proceso finalizó pero no se pudieron actualizar los datos." });
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Summary = "Error", Detail = ex.Message });
        }
        finally
        {
            isReprocessingPage = false;
            StateHasChanged();
        }
    }

    private void LoadOutputFiles()
    {
        try
        {
            string outputsPath = Path.Combine(jobDir, "outputs");
            if (Directory.Exists(outputsPath))
