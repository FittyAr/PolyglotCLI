@using PolyglotCLI
@using System.IO
@using System.Linq
@using System.Collections.Generic
@using Cropper.Blazor.Components
@using Cropper.Blazor.Models
@inject DialogService DialogService
@inject NotificationService NotificationService
@inject PolyglotCLI.AppConfig Config

<div class="job-details-dialog-content" style="display: flex; flex-direction: column; height: 100%; min-height: 0; overflow: hidden;">
    <style>
        .job-details-dialog-content .rz-tabview {
            display: flex !important;
            flex-direction: column !important;
            flex-grow: 1 !important;
            min-height: 0 !important;
            height: 100% !important;
        }
        .job-details-dialog-content .rz-tabview-panels {
            flex-grow: 1 !important;
            min-height: 0 !important;
            display: flex !important;
            flex-direction: column !important;
            padding: 12px 0 0 0 !important;
            height: 100% !important;
        }
        .job-details-dialog-content .rz-tabview-panel {
            flex-grow: 1 !important;
            min-height: 0 !important;
            display: flex !important;
            flex-direction: column !important;
            height: 100% !important;
        }
    </style>

    <RadzenPanel AllowCollapse="true" Collapsed="@isDetailsCollapsed" Collapse="@(() => isDetailsCollapsed = true)" Expand="@(() => isDetailsCollapsed = false)" class="rz-mb-4" Style="background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 12px; flex-shrink: 0;">
        <HeaderTemplate>
            <div style="display: flex; align-items: center; gap: 8px;">
                <RadzenIcon Icon="info" Style="font-size: 1.2rem; color: #6366f1;" />
                <RadzenText TextStyle="TextStyle.Subtitle2" style="font-weight: bold; margin: 0;">Detalles del Trabajo</RadzenText>
            </div>
        </HeaderTemplate>
        <ChildContent>
            <RadzenRow Gap="1rem" Style="padding-top: 8px;">
                <RadzenColumn Size="3">
                    <RadzenText TextStyle="TextStyle.Caption" style="color: #b0bec5; margin: 0;">Creado el</RadzenText>
                    <RadzenText TextStyle="TextStyle.Body2" style="font-weight: bold; margin: 0;">@Job.CreatedAt.ToString("d/M/yyyy HH:mm")</RadzenText>
                </RadzenColumn>
                <RadzenColumn Size="3">
                    <RadzenText TextStyle="TextStyle.Caption" style="color: #b0bec5; margin: 0;">Idioma Destino</RadzenText>
                    <RadzenText TextStyle="TextStyle.Body2" style="font-weight: bold; margin: 0;">@Job.TargetLanguage</RadzenText>
                </RadzenColumn>
                <RadzenColumn Size="3">
                    <RadzenText TextStyle="TextStyle.Caption" style="color: #b0bec5; margin: 0;">Modelo LLM</RadzenText>
                    <RadzenText TextStyle="TextStyle.Body2" style="font-weight: bold; margin: 0;">@(!string.IsNullOrEmpty(Job.ModelName) ? Job.ModelName : "Defecto del Servidor")</RadzenText>
                </RadzenColumn>
                <RadzenColumn Size="3">
                    <RadzenText TextStyle="TextStyle.Caption" style="color: #b0bec5; margin: 0;">Estado General</RadzenText>
                    <div>
                        <RadzenBadge BadgeStyle="@GetBadgeStyle(Job.Status)" Text="@Job.Status" />
                    </div>
                </RadzenColumn>
            </RadzenRow>
        </ChildContent>
    </RadzenPanel>

    <RadzenTabs RenderMode="TabRenderMode.Client" class="rz-m-0" Style="flex-grow: 1; display: flex; flex-direction: column; min-height: 0;">
    <Tabs>
        <RadzenTabsItem Text="Resumen y Progreso" Icon="assignment">
            <RadzenText TextStyle="TextStyle.Subtitle1" class="rz-my-3" style="font-weight: bold;">Archivos del Trabajo</RadzenText>
            
            <RadzenDataGrid Data="@Job.Files" TItem="JobFileManifest" AllowPaging="true" PageSize="5" class="rz-mb-4">
                <Template Context="file">
                    <RadzenCard Style="padding: 1rem; background: rgba(255, 255, 255, 0.02); border: 1px solid rgba(255, 255, 255, 0.05);">
                        <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-mb-2" style="font-weight: bold;">Progreso por Página / Fragmento</RadzenText>
                        @if(file.Pages != null && file.Pages.Count > 0)
                        {
                            <RadzenDataGrid Data="@file.Pages" TItem="JobPageManifest" AllowPaging="false" AllowSorting="false">
                                <Columns>
                                    <RadzenDataGridColumn TItem="JobPageManifest" Property="PageNumber" Title="Pág/Chunk" Width="90px" TextAlign="TextAlign.Center" />
                                    
                                    <RadzenDataGridColumn TItem="JobPageManifest" Title="Extracción / OCR" Width="180px">
                                        <Template Context="pageItem">
                                            @if(pageItem.OcrCompleted)
                                            {
                                                <span style="color: #4caf50; display: inline-flex; align-items: center; gap: 4px;">
                                                    <RadzenIcon Icon="check_circle" Style="color: #4caf50; font-size: 1.1rem; vertical-align: middle;" /> Completado
                                                </span>
                                            }
                                            else if(!string.IsNullOrEmpty(pageItem.OcrError))
                                            {
                                                <span style="color: #f44336; display: inline-flex; align-items: center; gap: 4px;" title="@pageItem.OcrError">
                                                    <RadzenIcon Icon="error" Style="color: #f44336; font-size: 1.1rem; vertical-align: middle;" /> Falló
                                                </span>
                                            }
                                            else
                                            {
                                                <span style="color: #ffb74d; display: inline-flex; align-items: center; gap: 4px;">
                                                    <RadzenIcon Icon="hourglass_empty" Style="color: #ffb74d; font-size: 1.1rem; vertical-align: middle;" /> Pendiente
                                                </span>
                                            }
                                        </Template>
                                    </RadzenDataGridColumn>

                                    <RadzenDataGridColumn TItem="JobPageManifest" Title="Traducción" Width="180px">
                                        <Template Context="pageItem">
                                            @if(pageItem.TranslationCompleted)
                                            {
                                                <span style="color: #4caf50; display: inline-flex; align-items: center; gap: 4px;">
                                                    <RadzenIcon Icon="check_circle" Style="color: #4caf50; font-size: 1.1rem; vertical-align: middle;" /> Completado
                                                </span>
                                            }
                                            else if(!string.IsNullOrEmpty(pageItem.TranslationError))
                                            {
                                                <span style="color: #f44336; display: inline-flex; align-items: center; gap: 4px;" title="@pageItem.TranslationError">
                                                    <RadzenIcon Icon="error" Style="color: #f44336; font-size: 1.1rem; vertical-align: middle;" /> Falló
                                                </span>
                                            }
                                            else
                                            {
                                                <span style="color: #ffb74d; display: inline-flex; align-items: center; gap: 4px;">
                                                    <RadzenIcon Icon="hourglass_empty" Style="color: #ffb74d; font-size: 1.1rem; vertical-align: middle;" /> Pendiente
                                                </span>
                                            }
                                        </Template>
                                    </RadzenDataGridColumn>

                                    <RadzenDataGridColumn TItem="JobPageManifest" Title="Revisión" Width="180px">
                                        <Template Context="pageItem">
                                            @if(pageItem.ReviewCompleted)
                                            {
                                                <span style="color: #4caf50; display: inline-flex; align-items: center; gap: 4px;">
                                                    <RadzenIcon Icon="check_circle" Style="color: #4caf50; font-size: 1.1rem; vertical-align: middle;" /> Completado
                                                </span>
                                            }
                                            else if(!string.IsNullOrEmpty(pageItem.ReviewError))
                                            {
                                                <span style="color: #f44336; display: inline-flex; align-items: center; gap: 4px;" title="@pageItem.ReviewError">
                                                    <RadzenIcon Icon="error" Style="color: #f44336; font-size: 1.1rem; vertical-align: middle;" /> Falló
                                                </span>
                                            }
                                            else
                                            {
                                                <span style="color: #ffb74d; display: inline-flex; align-items: center; gap: 4px;">
                                                    <RadzenIcon Icon="hourglass_empty" Style="color: #ffb74d; font-size: 1.1rem; vertical-align: middle;" /> Pendiente/No req.
                                                </span>
                                            }
                                        </Template>
                                    </RadzenDataGridColumn>

                                    <RadzenDataGridColumn TItem="JobPageManifest" Title="Conversión Doc" Width="180px">
                                        <Template Context="pageItem">
                                            <span style="@(pageItem.ConversionCompleted ? "color: #4caf50;" : "color: #b0bec5;") display: inline-flex; align-items: center; gap: 4px;">
                                                <RadzenIcon Icon="@(pageItem.ConversionCompleted ? "check_circle" : "help_outline")" Style="@((pageItem.ConversionCompleted ? "color: #4caf50;" : "color: #b0bec5;") + " font-size: 1.1rem; vertical-align: middle;")" />
                                                @(pageItem.ConversionCompleted ? "Completado" : "Pendiente/No req.")
                                            </span>
                                        </Template>
                                    </RadzenDataGridColumn>
                                </Columns>
                            </RadzenDataGrid>
                        }
                        else
                        {
                            <span style="color: #b0bec5;">No hay páginas o fragmentos registrados aún para este archivo.</span>
                        }
                    </RadzenCard>
                </Template>
                <Columns>
                    <RadzenDataGridColumn TItem="JobFileManifest" Property="OriginalFileName" Title="Nombre del Archivo Original" />
                    <RadzenDataGridColumn TItem="JobFileManifest" Property="Completed" Title="Estado del Archivo" Width="130px" TextAlign="TextAlign.Center">
                        <Template Context="file">
                            <RadzenBadge BadgeStyle="@(file.Completed ? BadgeStyle.Success : BadgeStyle.Danger)" Text="@(file.Completed ? "Completado" : "Incompleto")" />
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="JobFileManifest" Property="Pages.Count" Title="Pág/Chunks Totales" Width="160px" TextAlign="TextAlign.Center" />
                </Columns>
            </RadzenDataGrid>
        </RadzenTabsItem>

        <RadzenTabsItem Text="Verificador de Páginas " Icon="find_in_page">
            <RadzenRow class="rz-mt-3" Style="flex-grow: 1; min-height: 0; display: flex; height: 100%;">
                <RadzenColumn Size="2" Style="display: flex; flex-direction: column; min-height: 0; height: 100%;">
                    <RadzenCard style="flex-grow: 1; background: rgba(0,0,0,0.15); display: flex; flex-direction: column; gap: 12px; min-height: 0; height: 100%; padding: 12px !important;">
                        <RadzenText TextStyle="TextStyle.Subtitle2" style="font-weight: bold;">1. Documentos</RadzenText>
                        @if (jsonDataFiles == null || jsonDataFiles.Count == 0)
                        {
                            <div style="padding: 6px; color: #b0bec5; font-size: 0.85rem;">No hay documentos JSON disponibles.</div>
                        }
                        else
                        {
                            <RadzenListBox Data="@jsonDataFiles" TValue="JsonFileEntry" Value="@selectedJsonEntry" Change="@((args) => OnSelectJsonFile((JsonFileEntry)args))" style="width: 100%; background: transparent; border: 1px solid rgba(255,255,255,0.08);">
                                <Template Context="doc">
                                    <div style="display: flex; align-items: center; gap: 6px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                        <RadzenIcon Icon="description" Style="font-size: 1rem; color: #6366f1; min-width: 16px;" />
                                        <span title="@doc.DisplayName" style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap; flex-grow: 1;">@doc.DisplayName</span>
                                        <span style="color: #b0bec5; font-size: 0.75rem;">@doc.PageCount</span>
                                    </div>
                                </Template>
                            </RadzenListBox>
                        }

                        @if (pageDataList != null && pageDataList.Count > 0)
                        {
                            <RadzenText TextStyle="TextStyle.Subtitle2" style="font-weight: bold; margin-top: 8px;">2. Selecciona Página</RadzenText>
                            <RadzenListBox Data="@pageDataList" TValue="DocumentPageData" Value="@selectedPageData" Change="@((args) => OnSelectPage((DocumentPageData)args))" style="flex-grow: 1; height: 100%; min-height: 0; background: transparent; border: 1px solid rgba(255,255,255,0.08);">
                                <Template Context="p">
                                    <div style="display: flex; align-items: center; justify-content: space-between; width: 100%;">
                                        <span>Pág / Chunk @p.PageNumber</span>
                                        <div style="display: flex; gap: 4px; align-items: center;">
                                            @if (pendingTranslationEdits.ContainsKey(p.PageNumber))
                                            {
                                                <RadzenIcon Icon="edit" Style="color: #f59e0b; font-size: 0.85rem;" title="Editada en esta sesión" />
                                            }
                                            <RadzenIcon Icon="@(p.IsOcrSuccessful ? "check_circle" : "error")" Style="@(p.IsOcrSuccessful ? "color: #10b981; font-size: 1rem;" : "color: #ef4444; font-size: 1rem;")" />
                                            <RadzenIcon Icon="@(p.IsTranslationSuccessful ? "check_circle" : "error")" Style="@(p.IsTranslationSuccessful ? "color: #10b981; font-size: 1rem;" : "color: #ef4444; font-size: 1rem;")" />
                                        </div>
                                    </div>
                                </Template>
                            </RadzenListBox>
                        }
                    </RadzenCard>
                </RadzenColumn>
                <RadzenColumn Size="10" Style="display: flex; flex-direction: column; min-height: 0; height: 100%;">
                    <RadzenCard style="flex-grow: 1; background: rgba(0,0,0,0.15); display: flex; flex-direction: column; min-height: 0; height: 100%; padding: 12px !important;">
                        @if (selectedPageData != null)
                        {
                            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
                                <RadzenText TextStyle="TextStyle.Subtitle1" style="font-weight: bold; margin: 0;">
                                    Visualizando Página @selectedPageData.PageNumber de @(pageDataList?.Count ?? 0)
                                    @if (pendingTranslationEdits.Count > 0)
                                    {
                                        <span style="color: #f59e0b; font-size: 0.85rem; font-weight: normal; margin-left: 8px;">
                                            · @pendingTranslationEdits.Count página(s) editada(s) en esta sesión
                                        </span>
                                    }
                                </RadzenText>
                                <RadzenButton Text="Re-procesar esta página" Icon="autorenew" ButtonStyle="ButtonStyle.Warning" Size="ButtonSize.Small" Click="@(() => ReprocessPage())" IsBusy="@isReprocessingPage" BusyText="Procesando..." />
                            </div>
                                     <RadzenRow Gap="1rem" Style="flex-grow: 1; min-height: 0; display: flex; height: 100%;">
                                <RadzenColumn Size="6" Style="display: flex; flex-direction: column; min-height: 0; height: 100%;">
                                    <RadzenTabs RenderMode="TabRenderMode.Client" Style="flex-grow: 1; display: flex; flex-direction: column; min-height: 0; height: 100%;">
                                        <Tabs>
                                            <RadzenTabsItem Text="Original (PDF / Imagen)" Icon="image">
                                                <div style="position: relative; flex-grow: 1; display: flex; flex-direction: column; margin-top: 8px; border: 1px solid rgba(255,255,255,0.08); border-radius: 4px; overflow: hidden; background: #000; min-height: 0; height: 100%;">
                                                    @if (hasPageImage && !string.IsNullOrEmpty(pageImageBase64))
                                                    {
                                                        <div style="display: flex; align-items: center; gap: 4px; padding: 6px 8px; background: rgba(15, 23, 42, 0.85); border-bottom: 1px solid rgba(255,255,255,0.08); flex-shrink: 0; position: relative; z-index: 10;">
                                                            <RadzenButton Icon="zoom_in" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.ExtraSmall" Click="@ZoomInClick" Title="Acercar" Disabled="@(cropperRef == null)" />
                                                            <RadzenButton Icon="zoom_out" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.ExtraSmall" Click="@ZoomOutClick" Title="Alejar" Disabled="@(cropperRef == null)" />
                                                            <RadzenButton Icon="restart_alt" ButtonStyle="ButtonStyle.Secondary" Size="ButtonSize.ExtraSmall" Click="@ResetPageZoom" Title="Restablecer" Disabled="@(cropperRef == null)" />
                                                            <span style="flex-grow: 1; color: #94a3b8; font-size: 0.75rem; margin-left: 8px;">Arrastra para mover · Rueda para zoom · Doble clic para acercar</span>
                                                        </div>
                                                        <div style="flex-grow: 1; min-height: 0; background: #000; position: relative; height: 100%;">
                                                            <CropperComponent @ref="cropperRef"
                                                                             Src="@($"data:image/png;base64,{pageImageBase64}")"
                                                                             Options="cropperOptions"
                                                                             Class="polyglot-cropper"
                                                                             OnReadyEvent="OnCropperReady" />
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <div style="display: flex; align-items: center; justify-content: center; height: 100%; color: #b0bec5; font-size: 0.9rem; padding: 12px; text-align: center;">
                                                            No hay imagen renderizada disponible para este tipo de documento.
                                                        </div>
                                                    }
                                                </div>
                                            </RadzenTabsItem>
                                        </Tabs>
                                    </RadzenTabs>
                                </RadzenColumn>
                                <RadzenColumn Size="6" Style="display: flex; flex-direction: column; min-height: 0; height: 100%;">
                                    <RadzenTabs RenderMode="TabRenderMode.Client" Style="flex-grow: 1; display: flex; flex-direction: column; min-height: 0; height: 100%;">
                                        <Tabs>
                                            <RadzenTabsItem Text="Traducción" Icon="translate">
                                                <div style="flex-grow: 1; display: flex; flex-direction: column; margin-top: 8px; min-height: 0; height: 100%;">
                                                    <div style="display: flex; justify-content: flex-end; gap: 6px; margin-bottom: 8px; flex-shrink: 0;">
                                                        <RadzenButton Icon="@(isEditingTranslation ? "visibility" : "edit")"
                                                                      Text="@(isEditingTranslation ? "Vista previa" : "Editar")"
                                                                      ButtonStyle="ButtonStyle.Light"
                                                                      Size="ButtonSize.ExtraSmall"
                                                                      Click="@(() => isEditingTranslation = !isEditingTranslation)" />
                                                    </div>
                                                    @if (isEditingTranslation)
                                                    {
                                                        <RadzenTextArea @bind-Value="selectedPageData.TranslatedText" style="flex-grow: 1; font-family: monospace; font-size: 0.9rem; background: #0f172a; color: #cbd5e1; border: 1px solid rgba(255,255,255,0.08); padding: 12px; border-radius: 4px; resize: none; min-height: 0; height: 100%;" Change="@OnTranslationEdited" />
                                                    }
                                                    else
                                                    {
                                                        <div style="flex-grow: 1; overflow-y: auto; background: #0f172a; color: #cbd5e1; border: 1px solid rgba(255,255,255,0.08); border-radius: 4px; padding: 12px; min-height: 0; height: 100%;">
                                                            @if (!string.IsNullOrWhiteSpace(selectedPageData.TranslatedText))
                                                            {
                                                                <RadzenMarkdown Text="@GetMarkdownForPreview(selectedPageData.TranslatedText)" />
                                                            }
                                                            else
                                                            {
                                                                <div style="color: #b0bec5; font-size: 0.9rem;">Sin contenido para previsualizar.</div>
                                                            }
                                                        </div>
                                                    }
                                                </div>
                                            </RadzenTabsItem>
                                            <RadzenTabsItem Text="Texto Extraído (OCR)" Icon="description">
                                                <div style="flex-grow: 1; display: flex; flex-direction: column; margin-top: 8px; min-height: 0; height: 100%;">
                                                    <pre style="flex-grow: 1; margin: 0; padding: 12px; font-family: monospace; font-size: 0.9rem; color: #94a3b8; white-space: pre-wrap; background: #0f172a; border: 1px solid rgba(255,255,255,0.08); border-radius: 4px; height: 100%; overflow-y: auto; min-height: 0;">@selectedPageData.OriginalText</pre>
                                                </div>
                                            </RadzenTabsItem>
                                            <RadzenTabsItem Text="Pensamiento (Reasoning)" Icon="psychology">
                                                <div style="flex-grow: 1; display: flex; flex-direction: column; margin-top: 8px; min-height: 0; height: 100%;">
                                                    @if (!string.IsNullOrEmpty(selectedPageData.ThoughtText))
                                                    {
                                                        <pre style="flex-grow: 1; margin: 0; padding: 12px; font-family: monospace; font-size: 0.9rem; color: #f59e0b; white-space: pre-wrap; background: #0b0f19; border: 1px solid rgba(255,255,255,0.08); border-radius: 4px; height: 100%; overflow-y: auto; min-height: 0;">@selectedPageData.ThoughtText</pre>
                                                    }
                                                    else
                                                    {
                                                        <div style="display: flex; align-items: center; justify-content: center; height: 100%; color: #b0bec5; font-size: 0.9rem; border: 1px solid rgba(255,255,255,0.08); border-radius: 4px; background: #0b0f19; min-height: 0;">
                                                            No hay trazas de razonamiento (&lt;think&gt;) disponibles para esta página.
                                                        </div>
                                                    }
                                                </div>
                                            </RadzenTabsItem>
                                        </Tabs>
                                    </RadzenTabs>
                                </RadzenColumn>
                            </RadzenRow>
                        }
                        else
                        {
                            <div style="display: flex; align-items: center; justify-content: center; flex-grow: 1; color: #b0bec5; flex-direction: column; gap: 8px; height: 100%; min-height: 0;">
                                <RadzenIcon Icon="find_in_page" Style="font-size: 3rem; color: #6366f1;" />
                                <span>Selecciona un documento y una página del panel izquierdo para comenzar el análisis visual.</span>
                            </div>
                        }
                    </RadzenCard>
                </RadzenColumn>
            </RadzenRow>
        </RadzenTabsItem>

        <RadzenTabsItem Text="Archivos Generados (.md / .docx)" Icon="folder_open">
            <RadzenRow class="rz-mt-3" Style="flex-grow: 1; min-height: 0; display: flex; height: 100%;">
                <RadzenColumn Size="4" Style="display: flex; flex-direction: column; min-height: 0; height: 100%;">
                    <RadzenCard style="flex-grow: 1; overflow-y: auto; background: rgba(0,0,0,0.15); display: flex; flex-direction: column; min-height: 0; height: 100%; padding: 12px !important;">
                        <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-mb-2" style="font-weight: bold; flex-shrink: 0;">Archivos en el Directorio de Salida</RadzenText>
                        @if (outputFiles.Count == 0)
                        {
                            <div style="padding: 10px; color: #b0bec5; font-size: 0.9rem; flex-grow: 1;">No se encontraron archivos en la carpeta de salida del trabajo.</div>
                        }
                        else
                        {
                            <RadzenListBox Data="@outputFiles" TValue="string" style="width: 100%; flex-grow: 1; height: 100%; min-height: 0; background: transparent; border: none;" Change="@((args) => SelectOutputFile((string)args))">
                                <Template Context="path">
                                    <div style="display: flex; align-items: center; gap: 8px;">
                                        <RadzenIcon Icon="@(path.EndsWith(".md", StringComparison.OrdinalIgnoreCase) ? "article" : "description")" Style="font-size: 1.2rem; color: #6366f1;" />
                                        <span>@Path.GetFileName(path)</span>
                                    </div>
                                </Template>
                            </RadzenListBox>
                        }
                    </RadzenCard>
                </RadzenColumn>
                <RadzenColumn Size="8" Style="display: flex; flex-direction: column; min-height: 0; height: 100%;">
                    <RadzenCard style="flex-grow: 1; display: flex; flex-direction: column; background: rgba(0,0,0,0.15); min-height: 0; height: 100%; padding: 12px !important;">
                        <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-mb-2" style="font-weight: bold; flex-shrink: 0;">
                            Previsualización: @(selectedOutputFileName ?? "Selecciona un archivo")
                        </RadzenText>
                        @if (selectedOutputFileContent != null)
                        {
                            <div class="virtual-console flex-grow-1" style="flex-grow: 1; overflow-y: auto; white-space: pre-wrap; background-color: #030712; color: #cbd5e1; font-family: monospace; padding: 12px; border-radius: 6px; min-height: 0; height: 100%;">@selectedOutputFileContent</div>
                        }
                        else
                        {
                            <div style="display: flex; align-items: center; justify-content: center; flex-grow: 1; color: #b0bec5; height: 100%; min-height: 0;">
                                Selecciona un archivo de texto/markdown de la lista para ver su contenido.
                            </div>
                        }
                    </RadzenCard>
                </RadzenColumn>
            </RadzenRow>
        </RadzenTabsItem>

        <RadzenTabsItem Text="Imágenes Extraídas (PDF)" Icon="image">
            <RadzenRow class="rz-mt-3" Style="flex-grow: 1; min-height: 0; display: flex; height: 100%;">
                <RadzenColumn Size="2" Style="display: flex; flex-direction: column; min-height: 0; height: 100%;">
                    <RadzenCard style="flex-grow: 1; overflow-y: auto; background: rgba(0,0,0,0.15); padding: 8px; display: flex; flex-direction: column; min-height: 0; height: 100%;">
                        <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-mb-2" style="font-weight: bold; font-size: 0.9rem; flex-shrink: 0;">Páginas (PNG)</RadzenText>
                        @if (tempImages.Count == 0)
                        {
                            <div style="padding: 10px; color: #b0bec5; font-size: 0.8rem; flex-grow: 1;">No se encontraron imágenes.</div>
                        }
                        else
                        {
                            <RadzenListBox Data="@tempImages" TValue="string" style="width: 100%; flex-grow: 1; height: 100%; min-height: 0; background: transparent; border: none; font-size: 0.8rem;" Change="@((args) => SelectImage((string)args))">
                                <Template Context="path">
                                    <div style="display: flex; align-items: center; gap: 4px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                        <RadzenIcon Icon="image" Style="font-size: 1rem; color: #10b981; min-width: 16px;" />
                                        <span title="@Path.GetFileName(path)">@Path.GetFileName(path)</span>
                                    </div>
                                </Template>
                            </RadzenListBox>
                        }
                    </RadzenCard>
                </RadzenColumn>
                <RadzenColumn Size="10" Style="display: flex; flex-direction: column; min-height: 0; height: 100%;">
                    <RadzenCard style="flex-grow: 1; display: flex; flex-direction: column; background: rgba(0,0,0,0.15); min-height: 0; height: 100%; padding: 12px !important;">
                        <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-mb-2" style="font-weight: bold; width: 100%; flex-shrink: 0;">
                            Visor: @(selectedImageName ?? "Selecciona una página")
                        </RadzenText>
                        @if (selectedImageBase64 != null)
                        {
                            <div style="flex-grow: 1; width: 100%; overflow: auto; border: 1px solid rgba(255,255,255,0.05); padding: 8px; border-radius: 4px; background: #000; display: block; text-align: center; min-height: 0; height: 100%;">
                                <img src="data:image/png;base64,@selectedImageBase64" style="width: 100%; height: auto; display: block; margin: 0 auto;" />
                            </div>
                        }
                        else
                        {
                            <div style="display: flex; align-items: center; justify-content: center; flex-grow: 1; color: #b0bec5; height: 100%; min-height: 0;">
                                Selecciona una página de la lista para visualizar la imagen renderizada del PDF.
                            </div>
                        }
                    </RadzenCard>
                </RadzenColumn>
            </RadzenRow>
        </RadzenTabsItem>

        <RadzenTabsItem Text="Bitácora de Logs" Icon="article">
            <RadzenRow class="rz-mt-3" Style="flex-grow: 1; min-height: 0; display: flex; height: 100%;">
                <RadzenColumn Size="4" Style="display: flex; flex-direction: column; min-height: 0; height: 100%;">
                    <RadzenCard style="flex-grow: 1; overflow-y: auto; background: rgba(0,0,0,0.15); display: flex; flex-direction: column; min-height: 0; height: 100%; padding: 12px !important;">
                        <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-mb-2" style="font-weight: bold; flex-shrink: 0;">Archivos de Bitácora</RadzenText>
                        @if (logFiles.Count == 0)
                        {
                            <div style="padding: 10px; color: #b0bec5; font-size: 0.9rem; flex-grow: 1;">No se encontraron archivos de log en este trabajo.</div>
                        }
                        else
                        {
                            <RadzenListBox Data="@logFiles" TValue="string" style="width: 100%; flex-grow: 1; height: 100%; min-height: 0; background: transparent; border: none;" Change="@((args) => SelectLogFile((string)args))">
                                <Template Context="path">
                                    <div style="display: flex; align-items: center; gap: 8px;">
                                        <RadzenIcon Icon="receipt_long" Style="font-size: 1.2rem; color: #f59e0b;" />
                                        <span>@Path.GetFileName(path)</span>
                                    </div>
                                </Template>
                            </RadzenListBox>
                        }
                    </RadzenCard>
                </RadzenColumn>
                <RadzenColumn Size="8" Style="display: flex; flex-direction: column; min-height: 0; height: 100%;">
                    <RadzenCard style="flex-grow: 1; display: flex; flex-direction: column; background: rgba(0,0,0,0.15); min-height: 0; height: 100%; padding: 12px !important;">
                        <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-mb-2" style="font-weight: bold; flex-shrink: 0;">
                            Contenido: @(selectedLogFileName ?? "Selecciona un log")
                        </RadzenText>
                        @if (selectedLogFileContent != null)
                        {
                            <div class="virtual-console flex-grow-1" style="flex-grow: 1; overflow-y: auto; white-space: pre-wrap; background-color: #030712; color: #f59e0b; font-family: monospace; padding: 12px; border-radius: 6px; min-height: 0; height: 100%;">@selectedLogFileContent</div>
                        }
                        else
                        {
                            <div style="display: flex; align-items: center; justify-content: center; flex-grow: 1; color: #b0bec5; height: 100%; min-height: 0;">
                                Selecciona una bitácora para previsualizar los eventos registrados en el backend.
                            </div>
                        }
                    </RadzenCard>
                </RadzenColumn>
            </RadzenRow>
        </RadzenTabsItem>
    </Tabs>
</RadzenTabs>

<div class="rz-text-align-right rz-mt-4" style="flex-shrink: 0; margin-top: 12px !important;">
    <RadzenButton Text="Cerrar" Click="@(() => DialogService.Close())" ButtonStyle="ButtonStyle.Secondary" />
</div>
</div>

@code {
    [Parameter]
    public JobManifest Job { get; set; } = default!;

    private string jobDir => Path.Combine(TranslationOrchestrator.GetJobsDirectory(), Job.JobId);

    private List<string> outputFiles = new List<string>();
    private string? selectedOutputFileContent = null;
    private string? selectedOutputFileName = null;

    private List<string> tempImages = new List<string>();
    private string? selectedImageBase64 = null;
    private string? selectedImageName = null;

    private List<string> logFiles = new List<string>();
    private string? selectedLogFileContent = null;
    private string? selectedLogFileName = null;

    // Verificador de páginas variables
    private class JsonFileEntry
    {
        public string JsonFileName { get; set; } = string.Empty;
        public string DisplayName { get; set; } = string.Empty;
        public int PageCount { get; set; }
    }

    private List<JsonFileEntry> jsonDataFiles = new List<JsonFileEntry>();
    private JsonFileEntry? selectedJsonEntry = null;
    private string? selectedJsonFile => selectedJsonEntry?.JsonFileName;
    private List<DocumentPageData> pageDataList = new List<DocumentPageData>();
    private DocumentPageData? selectedPageData = null;
    private bool hasPageImage = false;
    private string? pageImageBase64 = null;
    private int? lastCropperPageNumber = null;
    private bool isReprocessingPage = false;
    private bool isEditingTranslation = true;

    // Visor de imagen con Cropper.Blazor
    private CropperComponent? cropperRef = null;
    private readonly Options cropperOptions = new Options
    {
        ViewMode = ViewMode.Vm0,
        // DragMode es string en Options (se serializa a "crop"/"move"/"none")
        DragMode = "move",
        AutoCrop = false,
        AutoCropArea = 0,
        Background = false,
        CropBoxMovable = false,
        CropBoxResizable = false,
        Modal = false,
        Movable = true,
        Rotatable = false,
        Scalable = true,
        ToggleDragModeOnDblclick = false,
        Zoomable = true,
        ZoomOnWheel = true,
        ZoomOnTouch = true,
        WheelZoomRatio = 0.1m
    };

    // Registro explícito de traducciones editadas durante la sesión actual del diálogo,
    // indexado por PageNumber. Permite saber exactamente qué páginas se modificaron y
    // preservarlas frente a recargas del JSON (p. ej. reprocesar página).
    private Dictionary<int, string> pendingTranslationEdits = new Dictionary<int, string>();
    private bool isDetailsCollapsed = false;

    protected override void OnInitialized()
    {
        LoadOutputFiles();
        LoadTempImages();
        LoadLogFiles();
        LoadJsonDataFiles();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        int? currentPage = selectedPageData?.PageNumber;
        // Si el cropper esta montado y la pagina cambia, reemplaza la imagen sin
        // perder el estado de pan/zoom acumulado.
        if (cropperRef != null
            && currentPage != lastCropperPageNumber
            && hasPageImage
            && !string.IsNullOrEmpty(pageImageBase64))
        {
            try
            {
                await cropperRef.ReplaceAsync($"data:image/png;base64,{pageImageBase64}", false);
                lastCropperPageNumber = currentPage;
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Cropper replace error: {ex.Message}");
            }
        }
    }

    private void OnCropperReady(Cropper.Blazor.Events.JSEventData<Cropper.Blazor.Events.CropReadyEvent.CropReadyEvent> _)
    {
        // Tras montarse por primera vez, fija el lastCropperPageNumber para que
        // OnAfterRenderAsync no intente ReplaceAsync antes de tener un cropperRef.
        lastCropperPageNumber = selectedPageData?.PageNumber;
    }

    private Task ZoomInClick()
    {
        return InvokeZoom(+1);
    }

    private Task ZoomOutClick()
    {
        return InvokeZoom(-1);
    }

    private Task InvokeZoom(int direction)
    {
        if (cropperRef == null)
        {
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Warning,
                Summary = "Visor",
                Detail = "El visor aún no está inicializado."
            });
            return Task.CompletedTask;
        }
        try
        {
            cropperRef.Zoom(direction >= 0 ? 0.1m : -0.1m);
        }
        catch (Exception ex)
        {
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error,
                Summary = "Pan/Zoom",
                Detail = ex.Message
            });
        }
        return Task.CompletedTask;
    }

    private Task ResetPageZoom()
    {
        if (cropperRef == null)
        {
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Warning,
                Summary = "Visor",
                Detail = "El visor aún no está inicializado."
            });
            return Task.CompletedTask;
        }
        try
        {
            cropperRef.Reset();
        }
        catch (Exception ex)
        {
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error,
                Summary = "Pan/Zoom",
                Detail = ex.Message
            });
        }
        return Task.CompletedTask;
    }

    private void LoadJsonDataFiles()
    {
        try
        {
            string dataPath = Path.Combine(jobDir, "data");
            if (Directory.Exists(dataPath))
            {
                var files = Directory.GetFiles(dataPath, "*_data.json");
                jsonDataFiles = new List<JsonFileEntry>();
                foreach (var filePath in files)
                {
                    string jsonFileName = Path.GetFileName(filePath);
                    string normalized = jsonFileName.Replace("_data.json", "", StringComparison.OrdinalIgnoreCase);

                    JobFileManifest? matchedManifest = Job?.Files?.FirstOrDefault(f =>
                        string.Equals(Path.GetFileNameWithoutExtension(f.SourceFilePath), normalized, StringComparison.OrdinalIgnoreCase) ||
                        string.Equals(f.NormalizedFileName, normalized, StringComparison.OrdinalIgnoreCase) ||
                        string.Equals(Path.GetFileNameWithoutExtension(f.OriginalFileName), normalized, StringComparison.OrdinalIgnoreCase)
                    );

                    string display = matchedManifest != null && !string.IsNullOrEmpty(matchedManifest.OriginalFileName)
                        ? matchedManifest.OriginalFileName
                        : normalized;

                    int pageCount = 0;
                    try
                    {
                        string jsonStr = File.ReadAllText(filePath);
                        var pages = System.Text.Json.JsonSerializer.Deserialize<List<DocumentPageData>>(jsonStr);
                        pageCount = pages?.Count ?? 0;
                    }
                    catch { }

                    jsonDataFiles.Add(new JsonFileEntry
                    {
                        JsonFileName = jsonFileName,
                        DisplayName = display,
                        PageCount = pageCount
                    });
                }
            }
        }
        catch {}
    }

    private void OnSelectJsonFile(JsonFileEntry entry)
    {
        selectedJsonEntry = entry;
        selectedPageData = null;
        pageImageBase64 = null;
        hasPageImage = false;
        isEditingTranslation = true;
        // Cambiar de documento reinicia el registro de edits pendientes; los edits del
        // documento anterior ya quedaron persistidos en su JSON al dispararse Change.
        pendingTranslationEdits.Clear();

        if (entry == null) return;

        try
        {
            string filePath = Path.Combine(jobDir, "data", entry.JsonFileName);
            if (File.Exists(filePath))
            {
                string jsonStr = File.ReadAllText(filePath);
                pageDataList = System.Text.Json.JsonSerializer.Deserialize<List<DocumentPageData>>(jsonStr) ?? new List<DocumentPageData>();
                if (pageDataList.Count > 0)
                {
                    OnSelectPage(pageDataList[0]);
                }
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Summary = "Error al cargar páginas", Detail = ex.Message });
        }
    }

    private string GetMarkdownForPreview(string? text)
    {
        if (string.IsNullOrEmpty(text)) return string.Empty;
        return text.Replace("&nbsp;", " ");
    }

    private void OnSelectPage(DocumentPageData p)
    {
        selectedPageData = p;
        pageImageBase64 = null;
        hasPageImage = false;

        // Si hay un edit pendiente de esta sesión para la página recién seleccionada,
        // se aplica sobre el modelo para que el TextArea muestre la versión modificada.
        if (selectedPageData != null && pendingTranslationEdits.TryGetValue(p.PageNumber, out var pendingText))
        {
            selectedPageData.TranslatedText = pendingText;
        }

        if (selectedPageData == null || string.IsNullOrEmpty(selectedJsonFile)) return;

        try
        {
            string docName = selectedJsonFile.Replace("_data.json", "");
            string tempPath = Path.Combine(jobDir, "temp");
            
            string pngPath = Path.Combine(tempPath, $"{docName}_page_{p.PageNumber}.png");
            if (File.Exists(pngPath))
            {
                byte[] bytes = File.ReadAllBytes(pngPath);
                pageImageBase64 = Convert.ToBase64String(bytes);
                hasPageImage = true;
            }
        }
        catch {}
    }

    private async Task OnTranslationEdited(string newText)
    {
        if (selectedPageData == null || selectedJsonEntry == null) return;

        try
        {
            string filePath = Path.Combine(jobDir, "data", selectedJsonEntry.JsonFileName);
            if (File.Exists(filePath))
            {
                // Registra el edit en el diccionario de cambios pendientes de esta sesión.
                pendingTranslationEdits[selectedPageData.PageNumber] = newText;
                // Refleja el edit también en el modelo en memoria para que la UI sea coherente.
                selectedPageData.TranslatedText = newText;

                // Serializa el documento completo fusionando los edits pendientes sobre pageDataList,
                // de modo que cualquier página modificada en esta sesión quede persistida.
                var states = pageDataList.Select(d => new PageProcessState
                {
                    PageNumber = d.PageNumber,
                    OcrText = d.OriginalText,
                    TranslatedText = pendingTranslationEdits.TryGetValue(d.PageNumber, out var edited) ? edited : d.TranslatedText,
                    ReviewedText = d.ReviewedText,
                    OcrFailed = !d.IsOcrSuccessful,
                    TranslationFailed = !d.IsTranslationSuccessful,
                    OcrErrorMessage = d.OcrErrorMessage,
                    TranslationErrorMessage = d.TranslationErrorMessage,
                    ThoughtText = d.ThoughtText
                }).ToList();

                JobManifestService.SavePageStatesToJson(states, filePath);

                string sourceFileName = selectedJsonEntry.JsonFileName.Replace("_data.json", "");
                var fileManifest = Job.Files.Find(f => Path.GetFileNameWithoutExtension(f.SourceFilePath).Equals(sourceFileName, StringComparison.OrdinalIgnoreCase));
                if (fileManifest != null)
                {
                    string absoluteOutputDir = Config.AbsoluteOutputDirectory;
                    string outputPath = Path.Combine(absoluteOutputDir, $"{sourceFileName}_{Config.TargetLanguage}.md");

                    // Reconstruye la lista final con los edits aplicados para el markdown y copia.
                    var mergedForExport = pageDataList.Select(d => new DocumentPageData
                    {
                        PageNumber = d.PageNumber,
                        OriginalText = d.OriginalText,
                        TranslatedText = pendingTranslationEdits.TryGetValue(d.PageNumber, out var edited) ? edited : d.TranslatedText,
                        ReviewedText = d.ReviewedText,
                        IsOcrSuccessful = d.IsOcrSuccessful,
                        IsTranslationSuccessful = d.IsTranslationSuccessful,
                        OcrErrorMessage = d.OcrErrorMessage,
                        TranslationErrorMessage = d.TranslationErrorMessage,
                        UsedTemperature = d.UsedTemperature,
                        RetryCount = d.RetryCount,
                        ThoughtText = d.ThoughtText
                    }).ToList();

                    MarkdownWriter.ExportToMarkdown(outputPath, sourceFileName, Config.TargetLanguage, mergedForExport, false);

                    string outputsDir = Path.Combine(jobDir, "outputs");
                    if (!Directory.Exists(outputsDir)) Directory.CreateDirectory(outputsDir);
                    File.Copy(outputPath, Path.Combine(outputsDir, Path.GetFileName(outputPath)), true);

                    if (!string.IsNullOrEmpty(Config.DefaultOutputFormat) && Config.ModuleConversionEnabled)
                    {
                        await OutputFormatConverter.ConvertToFormatsAsync(outputPath, Config.DefaultOutputFormat);
                    }
                }
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Summary = "Error al guardar cambios", Detail = ex.Message });
        }
    }

    private async Task ReprocessPage()
    {
        if (selectedPageData == null || string.IsNullOrEmpty(selectedJsonFile)) return;

        isReprocessingPage = true;
        StateHasChanged();

        try
        {
            string sourceFileName = selectedJsonFile.Replace("_data.json", "");
            var fileManifest = Job.Files.Find(f => Path.GetFileNameWithoutExtension(f.SourceFilePath).Equals(sourceFileName, StringComparison.OrdinalIgnoreCase));
            
            if (fileManifest == null)
            {
                NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Summary = "Reprocesamiento", Detail = "No se pudo asociar el archivo de datos con el archivo de origen." });
                return;
            }

            bool success = await Task.Run(() => TranslationOrchestrator.ReprocessPageAsync(
                Job.JobId, 
                fileManifest.SourceFilePath, 
                selectedPageData.PageNumber, 
                Config
            ));

            if (success)
            {
                NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Success, Summary = "Reprocesamiento", Detail = $"Página {selectedPageData.PageNumber} procesada con éxito." });
                OnSelectJsonFile(selectedJsonEntry!);
            }
            else
            {
                NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Summary = "Reprocesamiento", Detail = "El proceso finalizó pero no se pudieron actualizar los datos." });
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Summary = "Error", Detail = ex.Message });
        }
        finally
        {
            isReprocessingPage = false;
            StateHasChanged();
        }
    }

    private void LoadOutputFiles()
    {
        try
        {
            string outputsPath = Path.Combine(jobDir, "outputs");
            if (Directory.Exists(outputsPath))
            {
                outputFiles = Directory.GetFiles(outputsPath).ToList();
            }
        }
        catch {}
    }

    private void SelectOutputFile(string path)
    {
        try
        {
            selectedOutputFileName = Path.GetFileName(path);
            if (path.EndsWith(".md", StringComparison.OrdinalIgnoreCase) || path.EndsWith(".txt", StringComparison.OrdinalIgnoreCase) || path.EndsWith(".json", StringComparison.OrdinalIgnoreCase) || path.EndsWith(".log", StringComparison.OrdinalIgnoreCase))
            {
                selectedOutputFileContent = File.ReadAllText(path);
            }
            else
            {
                selectedOutputFileContent = $"[Archivo binario o no legible en texto: {selectedOutputFileName}]";
            }
        }
        catch (Exception ex)
        {
            selectedOutputFileContent = $"Error al leer el archivo: {ex.Message}";
        }
    }

    private void LoadTempImages()
    {
        try
        {
            string tempPath = Path.Combine(jobDir, "temp");
            if (Directory.Exists(tempPath))
            {
                tempImages = Directory.GetFiles(tempPath, "*.png").ToList();
            }
        }
        catch {}
    }

    private void SelectImage(string path)
    {
        try
        {
            selectedImageName = Path.GetFileName(path);
            byte[] bytes = File.ReadAllBytes(path);
            selectedImageBase64 = Convert.ToBase64String(bytes);
        }
        catch (Exception ex)
        {
            selectedImageBase64 = null;
            selectedImageName = $"Error al cargar la imagen: {ex.Message}";
        }
    }

    private void LoadLogFiles()
    {
        try
        {
            string logsPath = Path.Combine(jobDir, "logs");
            if (Directory.Exists(logsPath))
            {
                logFiles = Directory.GetFiles(logsPath).ToList();
            }
        }
        catch {}
    }

    private void SelectLogFile(string path)
    {
        try
        {
            selectedLogFileName = Path.GetFileName(path);
            selectedLogFileContent = File.ReadAllText(path);
        }
        catch (Exception ex)
        {
            selectedLogFileContent = $"Error al leer los logs: {ex.Message}";
        }
    }

    private BadgeStyle GetBadgeStyle(string status)
    {
        return status switch {
            "Completed" => BadgeStyle.Success,
            "Failed" => BadgeStyle.Danger,
            "InProgress" => BadgeStyle.Warning,
            _ => BadgeStyle.Info
        };
    }
}
