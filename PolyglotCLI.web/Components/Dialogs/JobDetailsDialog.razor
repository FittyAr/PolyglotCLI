            }
        }
        catch {}
    }

    private void SelectOutputFile(string path)
    {
        try
        {
            selectedOutputFileName = Path.GetFileName(path);
            if (path.EndsWith(".md", StringComparison.OrdinalIgnoreCase) || path.EndsWith(".txt", StringComparison.OrdinalIgnoreCase) || path.EndsWith(".json", StringComparison.OrdinalIgnoreCase) || path.EndsWith(".log", StringComparison.OrdinalIgnoreCase))
            {
                selectedOutputFileContent = File.ReadAllText(path);
            }
            else
            {
                selectedOutputFileContent = $"[Archivo binario o no legible en texto: {selectedOutputFileName}]";
            }
        }
        catch (Exception ex)
        {
            selectedOutputFileContent = $"Error al leer el archivo: {ex.Message}";
        }
    }

