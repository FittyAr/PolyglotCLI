@using PolyglotCLI

<RadzenRow Gap="1rem" class="rz-mb-4">
    <RadzenColumn Size="12">
        <RadzenCheckBox @bind-Value="AppConfig.EnableReview" Name="cfgReview" />
        <RadzenLabel Text="Habilitar Revisión Post-Traducción con IA" Component="cfgReview" class="rz-ml-2" />
    </RadzenColumn>
</RadzenRow>
<RadzenRow Gap="1rem" class="rz-mb-4">
    <RadzenColumn Size="6">
        <RadzenLabel Text="Proveedor LLM para Revisión" class="rz-mb-2" />
        <RadzenDropDown Data="@providerOptions" @bind-Value="AppConfig.ReviewProvider" Change="@OnProviderChanged" class="rz-w-100" Disabled="@(!AppConfig.EnableReview)" />
    </RadzenColumn>
    <RadzenColumn Size="6">
        <div style="display: flex; gap: 0.5rem; align-items: flex-end;">
            <div style="flex-grow: 1;">
                <RadzenLabel Text="Modelo de Revisión" class="rz-mb-2" />
                <RadzenDropDown @bind-Value="AppConfig.ReviewModel" Data="@currentModels" class="rz-w-100" Placeholder="Seleccionar o escribir modelo de revisión..." AllowClear="true" AllowFiltering="true" AllowCustom="true" Disabled="@(!AppConfig.EnableReview)" />
            </div>
            <RadzenButton Icon="sync" ButtonStyle="ButtonStyle.Secondary" Click="@FetchModelsForProvider" Tooltip="Cargar modelos desde el servidor seleccionado" IsBusy="@isLoadingModels" Disabled="@(!AppConfig.EnableReview)" />
        </div>
    </RadzenColumn>
</RadzenRow>
<RadzenRow Gap="1rem" class="rz-mb-4">
    <RadzenColumn Size="6">
        <RadzenLabel Text="Temperatura Revisión (0.0 - 1.0)" class="rz-mb-2" />
        <RadzenNumeric @bind-Value="AppConfig.ReviewTemperature" TValue="double" Step="0.1" Min="@((decimal)0)" Max="@((decimal)1)" class="rz-w-100" Disabled="@(!AppConfig.EnableReview)" />
    </RadzenColumn>
    <RadzenColumn Size="6">
        <RadzenLabel Text="Timeout Revisión (segundos)" class="rz-mb-2" />
        <RadzenNumeric @bind-Value="AppConfig.ReviewTimeoutSeconds" TValue="int" class="rz-w-100" Disabled="@(!AppConfig.EnableReview)" />
    </RadzenColumn>
</RadzenRow>

@code {
    [Parameter]
    public PolyglotCLI.AppConfig AppConfig { get; set; } = default!;

    [Parameter]
    public List<string> AvailableModels { get; set; } = new();

    [Parameter]
    public bool IsTestingConnection { get; set; }

    [Parameter]
    public EventCallback OnLoadModels { get; set; }

    private List<string> currentModels = new();
    private bool isLoadingModels = false;

    private List<string> providerOptions => AppConfig?.GetTestedProviders() ?? new List<string>();

    protected override void OnInitialized()
    {
        UpdateModelsList();
    }

    protected override void OnParametersSet()
    {
        UpdateModelsList();
    }

    private async Task OnProviderChanged(object value)
    {
        if (value is string providerStr)
        {
            AppConfig.ReviewProvider = providerStr;
        }
        UpdateModelsList(true);
        await FetchModelsForProvider();
    }

    private void UpdateModelsList(bool providerChanged = false)
    {
        var savedModels = AppConfig.GetModelsForProvider(AppConfig.ReviewProvider);
        if (savedModels == null || savedModels.Count == 0)
        {
            var providerEnum = LlmProviderHelper.ParseProvider(AppConfig.ReviewProvider);
            savedModels = LlmProviderHelper.GetDefaultSuggestedModels(providerEnum);
        }
        currentModels = new List<string>(savedModels);

        if (providerChanged)
        {
            if (!string.IsNullOrEmpty(AppConfig.ReviewModel) && !currentModels.Contains(AppConfig.ReviewModel))
            {
                if (currentModels.Count > 0)
                {
                    AppConfig.ReviewModel = currentModels[0];
                }
                else
                {
                    AppConfig.ReviewModel = null;
                }
            }
        }
        else
        {
            if (!string.IsNullOrEmpty(AppConfig.ReviewModel) && !currentModels.Contains(AppConfig.ReviewModel))
            {
                currentModels.Add(AppConfig.ReviewModel);
            }
        }
    }

    private async Task FetchModelsForProvider()
    {
        isLoadingModels = true;
        StateHasChanged();
        try
        {
            using var client = LlmClientFactory.CreateClientForReview(null, AppConfig, AppConfig.ModelCheckTimeoutSeconds);
            var fetched = await client.GetAvailableModelsAsync();
            if (fetched.Count > 0)
            {
                AppConfig.SaveTestedProvider(AppConfig.ReviewProvider, AppConfig.GetProviderConfig(AppConfig.ReviewProvider).ApiUrl, AppConfig.GetApiKeyForProvider(AppConfig.ReviewProvider), fetched);
                currentModels = fetched;
            }
        }
        catch {}
        finally
        {
            isLoadingModels = false;
            StateHasChanged();
        }
    }
}
