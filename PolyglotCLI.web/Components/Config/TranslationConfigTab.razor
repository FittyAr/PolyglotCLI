@using PolyglotCLI

<RadzenRow Gap="1rem" class="rz-mb-4">
    <RadzenColumn Size="6">
        <RadzenLabel Text="Proveedor LLM para Traducción" class="rz-mb-2" />
        <RadzenDropDown Data="@providerOptions" @bind-Value="AppConfig.TranslationProvider" Change="@OnProviderChanged" class="rz-w-100" />
    </RadzenColumn>
    <RadzenColumn Size="6">
        <div style="display: flex; gap: 0.5rem; align-items: flex-end;">
            <div style="flex-grow: 1;">
                <RadzenLabel Text="Modelo de Traducción" class="rz-mb-2" />
                <RadzenDropDown @bind-Value="AppConfig.DefaultModel" Data="@currentModels" class="rz-w-100" Placeholder="Seleccionar o escribir modelo de traducción..." AllowClear="true" AllowFiltering="true" AllowCustom="true" />
            </div>
            <RadzenButton Icon="sync" ButtonStyle="ButtonStyle.Secondary" Click="@FetchModelsForProvider" Tooltip="Cargar modelos desde el servidor seleccionado" IsBusy="@isLoadingModels" />
        </div>
    </RadzenColumn>
</RadzenRow>
<RadzenRow Gap="1rem" class="rz-mb-4">
    <RadzenColumn Size="12">
        <RadzenLabel Text="Temperatura Traducción (0.0 - 1.0)" class="rz-mb-2" />
        <RadzenNumeric @bind-Value="AppConfig.Temperature" TValue="double" Step="0.1" Min="@((decimal)0)" Max="@((decimal)1)" class="rz-w-100" />
    </RadzenColumn>
</RadzenRow>
<RadzenRow Gap="1rem" class="rz-mb-4">
    <RadzenColumn Size="12">
        <RadzenLabel Text="Idioma Destino por Defecto" class="rz-mb-2" />
        <RadzenTextBox @bind-Value="AppConfig.TargetLanguage" class="rz-w-100" />
    </RadzenColumn>
</RadzenRow>
<RadzenRow Gap="1rem" class="rz-mb-4">
    <RadzenColumn Size="6">
        <RadzenLabel Text="Máx. Caracteres por Chunk" class="rz-mb-2" />
        <RadzenNumeric @bind-Value="AppConfig.MaxCharactersPerChunk" TValue="int" class="rz-w-100" />
    </RadzenColumn>
    <RadzenColumn Size="6">
        <RadzenLabel Text="Solapamiento de Chunks (caracteres)" class="rz-mb-2" />
        <RadzenNumeric @bind-Value="AppConfig.ChunkOverlapCharacters" TValue="int" class="rz-w-100" />
    </RadzenColumn>
</RadzenRow>
<RadzenRow Gap="1rem" class="rz-mb-4">
    <RadzenColumn Size="6">
        <RadzenLabel Text="Timeout Traducción (segundos)" class="rz-mb-2" />
        <RadzenNumeric @bind-Value="AppConfig.TranslationTimeoutSeconds" TValue="int" class="rz-w-100" />
    </RadzenColumn>
    <RadzenColumn Size="6" class="rz-align-self-center">
        <RadzenCheckBox @bind-Value="AppConfig.PreserveFormat" Name="cfgPreserve" />
        <RadzenLabel Text="Preservar formato original" Component="cfgPreserve" class="rz-ml-2" />
    </RadzenColumn>
</RadzenRow>

@code {
    [Parameter]
    public PolyglotCLI.AppConfig AppConfig { get; set; } = default!;

    [Parameter]
    public List<string> AvailableModels { get; set; } = new();

    [Parameter]
    public bool IsTestingConnection { get; set; }

    [Parameter]
    public EventCallback OnLoadModels { get; set; }

    private List<string> currentModels = new();
    private bool isLoadingModels = false;

    private List<string> providerOptions => AppConfig?.GetTestedProviders() ?? new List<string>();

    protected override void OnInitialized()
    {
        UpdateModelsList();
    }

    protected override void OnParametersSet()
    {
        UpdateModelsList();
    }

    private void OnProviderChanged(object value)
    {
        UpdateModelsList();
    }

    private void UpdateModelsList()
    {
        var savedModels = AppConfig.GetModelsForProvider(AppConfig.TranslationProvider);
        currentModels = new List<string>(savedModels);

        if (!string.IsNullOrEmpty(AppConfig.DefaultModel) && !currentModels.Contains(AppConfig.DefaultModel))
        {
            currentModels.Add(AppConfig.DefaultModel);
        }
    }

    private async Task FetchModelsForProvider()
    {
        isLoadingModels = true;
        StateHasChanged();
        try
        {
            using var client = LlmClientFactory.CreateClientForTranslation(null, AppConfig, AppConfig.ModelCheckTimeoutSeconds);
            var fetched = await client.GetAvailableModelsAsync();
            if (fetched.Count > 0)
            {
                AppConfig.SaveTestedProvider(AppConfig.TranslationProvider, AppConfig.GetProviderConfig(AppConfig.TranslationProvider).ApiUrl, AppConfig.GetApiKeyForProvider(AppConfig.TranslationProvider), fetched);
                currentModels = fetched;
            }
        }
        catch {}
        finally
        {
            isLoadingModels = false;
            StateHasChanged();
        }
    }
}
