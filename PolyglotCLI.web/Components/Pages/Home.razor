@page "/"

<PageTitle>Traductor - PolyglotCLI</PageTitle>

<RadzenRow>
    @if (!isConsoleExpanded)
    {
        <RadzenColumn SizeMD="7" SizeLG="8">
            <RadzenCard class="rz-mb-4">
            <RadzenText TextStyle="TextStyle.H4" class="rz-mb-4">Nueva Traducción</RadzenText>
            
            <RadzenTemplateForm Data="@options" Submit="@(async (CommandLineOptions args) => await RunTranslation(args))">
                
                <!-- Explorador de carpetas y discos -->
                <RadzenCard class="rz-mb-4 rz-p-4" style="background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.1);">
                    <RadzenText TextStyle="TextStyle.Subtitle1" class="rz-mb-2" style="font-weight: bold;">Explorador de Carpetas</RadzenText>
                    <RadzenRow Gap="1rem" AlignItems="AlignItems.Center">
                        @if (drives.Count > 0)
                        {
                            <RadzenColumn Size="3">
                                <RadzenLabel Text="Unidad" class="rz-mb-1" style="font-size: 0.85rem;" />
                                <RadzenDropDown @bind-Value="selectedDrive" Data="@drives" Change="@ChangeDrive" class="rz-w-100" />
                            </RadzenColumn>
                        }
                        <RadzenColumn Size="@(drives.Count > 0 ? 9 : 12)">
                            <RadzenLabel Text="Ruta del Directorio" class="rz-mb-1" style="font-size: 0.85rem;" />
                            <div style="display: flex; gap: 0.5rem;">
                                <RadzenTextBox @bind-Value="currentDirectory" style="flex-grow: 1;" />
                                <RadzenButton Icon="refresh" ButtonStyle="ButtonStyle.Secondary" Click="@(() => LoadDirectory(currentDirectory))" Tooltip="Cargar directorio" />
                            </div>
                        </RadzenColumn>
                    </RadzenRow>
                </RadzenCard>

                <!-- Grid de selección y configuración por archivo -->
                <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-mb-2" style="font-weight: bold;">Selección de Archivos y Configuración Individual</RadzenText>
                @if (fileSystemItems.Count > 0)
                {
                    <RadzenDataGrid Data="@fileSystemItems" TItem="FileSystemItem" SelectionMode="DataGridSelectionMode.Single" @bind-Value="@selectedRows" AllowFiltering="false" AllowSorting="false" PageSize="100" class="rz-mb-4" Style="max-height: 400px; overflow-y: auto;">
                        <Columns>
                            <!-- Selección -->
                            <RadzenDataGridColumn TItem="FileSystemItem" Width="55px" Sortable="false" Filterable="false" TextAlign="TextAlign.Center">
                                <HeaderTemplate>
                                    <RadzenCheckBox Value="@allSelected" TValue="bool" Change="@(val => SelectAllFiles(val))" />
                                </HeaderTemplate>
                                <Template Context="item">
                                    @if (!item.IsDirectory)
                                    {
                                        <RadzenCheckBox @bind-Value="item.IsSelected" />
                                    }
                                </Template>
                            </RadzenDataGridColumn>

                            <!-- Nombre -->
                            <RadzenDataGridColumn TItem="FileSystemItem" Title="Nombre" Width="260px">
                                <Template Context="item">
                                    @if (item.IsDirectory)
                                    {
                                        <span @onclick="@(() => LoadDirectory(item.FullPath))" style="cursor: pointer; font-weight: bold; color: #64b5f6; display: inline-flex; align-items: center;">
                                            <RadzenIcon Icon="folder" Style="margin-right: 8px; color: #ffca28; vertical-align: middle;" />
                                            @item.Name
                                        </span>
                                    }
                                    else
                                    {
                                        <span style="display: inline-flex; align-items: center;">
                                            <RadzenIcon Icon="insert_drive_file" Style="margin-right: 8px; color: #90a4ae; vertical-align: middle;" />
                                            @item.Name
                                        </span>
                                    }
                                </Template>
                            </RadzenDataGridColumn>

                            <!-- Tipo -->
                            <RadzenDataGridColumn TItem="FileSystemItem" Title="Tipo" Width="80px">
                                <Template Context="item">
                                    @(item.IsDirectory ? "<DIR>" : item.Extension.ToUpperInvariant())
                                </Template>
                            </RadzenDataGridColumn>

                            <!-- Método (sólo PDF) -->
                            <RadzenDataGridColumn TItem="FileSystemItem" Title="Método" Width="150px">
                                <Template Context="item">
                                    @if (!item.IsDirectory)
                                    {
                                        @if (item.Extension.Equals(".pdf", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <RadzenSelectBar @bind-Value="item.Mode" Size="ButtonSize.Small" TValue="string" style="font-size: 0.8rem;">
                                                <Items>
                                                    <RadzenSelectBarItem Value="@("text")" Text="Texto" />
                                                    <RadzenSelectBarItem Value="@("image")" Text="Imagen" />
                                                </Items>
                                            </RadzenSelectBar>
                                        }
                                        else
                                        {
                                            <span style="font-size: 0.85rem; color: #b0bec5;">@(item.Mode == "image" ? "Imagen" : "Texto")</span>
                                        }
                                    }
                                </Template>
                            </RadzenDataGridColumn>

                            <!-- Rango Páginas (sólo PDF) -->
                            <RadzenDataGridColumn TItem="FileSystemItem" Title="Páginas" Width="110px">
                                <Template Context="item">
                                    @if (!item.IsDirectory)
                                    {
                                        @if (item.Extension.Equals(".pdf", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <RadzenTextBox @bind-Value="item.PageRange" Style="width: 100%; height: 28px; font-size: 0.85rem;" Placeholder="todas" />
                                        }
                                        else
                                        {
                                            <span style="font-size: 0.85rem; color: #b0bec5;">-</span>
                                        }
                                    }
                                </Template>
                            </RadzenDataGridColumn>
                        </Columns>
                    </RadzenDataGrid>
                }
                else
                {
                    <RadzenAlert AlertStyle="AlertStyle.Info" AllowClose="false" class="rz-mb-4">
                        No hay archivos compatibles ni carpetas en este directorio.
                    </RadzenAlert>
                }

                <RadzenRow Gap="1rem" class="rz-mb-4">
                    <RadzenColumn Size="6">
                        <RadzenLabel Text="Idioma Destino" class="rz-mb-2" />
                        <RadzenTextBox @bind-Value="options.TargetLanguage" class="rz-w-100" />
                    </RadzenColumn>
                    <RadzenColumn Size="6">
                        <RadzenLabel Text="Formato de Salida Generado" class="rz-mb-2" />
                        <RadzenDropDown @bind-Value="options.SelectedFormat" Data="@Config.SupportedOutputFormats" class="rz-w-100" Placeholder="Ninguno (Solo MD)" AllowClear="true" />
                    </RadzenColumn>
                </RadzenRow>

                <RadzenRow Gap="1rem" class="rz-mb-4">
                    <RadzenColumn Size="4" class="rz-align-self-center">
                        <RadzenCheckBox @bind-Value="options.Transcribe" Name="optTranscribe" />
                        <RadzenLabel Text="Extraer Texto / OCR" Component="optTranscribe" class="rz-ml-2" />
                    </RadzenColumn>
                    <RadzenColumn Size="4" class="rz-align-self-center">
                        <RadzenCheckBox @bind-Value="options.Translate" Name="optTranslate" />
                        <RadzenLabel Text="Traducir Contenido" Component="optTranslate" class="rz-ml-2" />
                    </RadzenColumn>
                    <RadzenColumn Size="4" class="rz-align-self-center">
                        <RadzenCheckBox @bind-Value="options.Debug" Name="optDebug" />
                        <RadzenLabel Text="Modo Prueba (primeras 2 pág.)" Component="optDebug" class="rz-ml-2" />
                    </RadzenColumn>
                </RadzenRow>
                
                <!-- Prompt personalizado e IA -->
                <RadzenCard class="rz-mb-4 rz-p-4" style="background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.08);">
                    <RadzenText TextStyle="TextStyle.Subtitle1" class="rz-mb-2" style="font-weight: bold;">Instrucciones de Traducción Adicionales (Prompt)</RadzenText>
                    <RadzenRow class="rz-mb-3">
                        <RadzenColumn Size="12">
                            <RadzenTextArea @bind-Value="options.AdditionalPrompt" Rows="5" class="rz-w-100" Placeholder="Instrucciones adicionales para guiar la traducción..." />
                        </RadzenColumn>
                    </RadzenRow>
                    <RadzenRow>
                        <RadzenColumn Size="12">
                            <RadzenButton Text="Analizar Archivo (IA)" Icon="analytics" ButtonStyle="ButtonStyle.Info" 
                                          Click="@(async () => await AnalyzeFilePrompt())" 
                                          Disabled="@(isProcessing || selectedRows.Count != 1 || selectedRows[0].IsDirectory)" />
                                          
                            <RadzenButton Text="Mejorar Prompt (IA)" Icon="upgrade" ButtonStyle="ButtonStyle.Secondary" 
                                          Click="@(async () => await ImprovePrompt())" 
                                          Disabled="@(isProcessing || string.IsNullOrWhiteSpace(options.AdditionalPrompt))" class="rz-ml-2" />
                                          
                            <RadzenButton Text="Guardar Preajustes" Icon="save" ButtonStyle="ButtonStyle.Warning" 
                                          Click="@(async () => await SavePresets())" 
                                          Disabled="@isProcessing" class="rz-ml-2" />
                        </RadzenColumn>
                    </RadzenRow>
                </RadzenCard>

                <RadzenButton ButtonType="ButtonType.Submit" Text="Iniciar Traducción" Icon="play_arrow" 
                               ButtonStyle="ButtonStyle.Primary" BusyText="Procesando..." IsBusy="@isProcessing" class="rz-mt-2" />
                @if (isProcessing)
                {
                    <RadzenButton Text="Detener Proceso" Icon="stop" ButtonStyle="ButtonStyle.Danger" Click="@CancelProcess" class="rz-mt-2 rz-ml-2" />
                }
            </RadzenTemplateForm>
        </RadzenCard>
        </RadzenColumn>
    }

    <RadzenColumn SizeMD="@(isConsoleExpanded ? 12 : 5)" SizeLG="@(isConsoleExpanded ? 12 : 4)">
        <RadzenCard class="rz-h-100" style="display: flex; flex-direction: column; min-height: 500px;">
            <div style="display: flex; justify-content: space-between; align-items: center;" class="rz-mb-4">
                <RadzenText TextStyle="TextStyle.H6" style="margin: 0;">Consola de Progreso</RadzenText>
                <div>
                    <RadzenButton Icon="@(isAutoscrollEnabled ? "arrow_downward" : "remove")" 
                                  ButtonStyle="@(isAutoscrollEnabled ? ButtonStyle.Success : ButtonStyle.Secondary)" 
                                  Size="ButtonSize.Small" 
                                  Click="@ToggleAutoscroll" 
                                  Tooltip="@(isAutoscrollEnabled ? "Desactivar Auto-scroll" : "Activar Auto-scroll")" />
                    
                    <RadzenButton Icon="@(isConsoleExpanded ? "fullscreen_exit" : "fullscreen")" 
                                  ButtonStyle="ButtonStyle.Secondary" 
                                  Size="ButtonSize.Small" 
                                  Click="@ToggleConsoleExpansion" 
                                  Tooltip="@(isConsoleExpanded ? "Restaurar tamaño" : "Maximizar consola")" 
                                  class="rz-ml-2" />
                </div>
            </div>
            
            <div class="virtual-console flex-grow-1" id="consoleOutput" style="@(isConsoleExpanded ? "max-height: 800px; height: 600px;" : "")">
                @foreach(var log in logs)
                {
                    <div class="@log.CssClass">@log.Message</div>
                }
                @if(logs.Count == 0)
                {
                    <div class="log-debug">Esperando iniciar trabajo...</div>
                }
            </div>
            
        </RadzenCard>
    </RadzenColumn>
</RadzenRow>
