@page "/config"
@inject PolyglotCLI.AppConfig AppConfig

<PageTitle>Configuración - PolyglotCLI</PageTitle>

<RadzenCard class="rz-my-4">
    <RadzenText TextStyle="TextStyle.H4">Configuración de la Aplicación</RadzenText>
    <div class="rz-p-4">
        <RadzenTemplateForm Data="@AppConfig" Submit="@(async (PolyglotCLI.AppConfig args) => await SaveConfig(args))">
            <RadzenRow Gap="1rem" class="rz-mb-4">
                <RadzenColumn Size="12">
                    <RadzenLabel Text="URL de la API" />
                    <RadzenTextBox @bind-Value="AppConfig.ApiUrl" class="rz-w-100" />
                </RadzenColumn>
            </RadzenRow>

            <RadzenRow Gap="1rem" class="rz-mb-4">
                <RadzenColumn Size="6">
                    <RadzenLabel Text="Modelo por Defecto" />
                    <RadzenTextBox @bind-Value="AppConfig.DefaultModel" class="rz-w-100" />
                </RadzenColumn>
                <RadzenColumn Size="6">
                    <RadzenLabel Text="Idioma Destino por Defecto" />
                    <RadzenTextBox @bind-Value="AppConfig.TargetLanguage" class="rz-w-100" />
                </RadzenColumn>
            </RadzenRow>
            
            <RadzenRow Gap="1rem" class="rz-mb-4">
                <RadzenColumn Size="12">
                    <RadzenLabel Text="Directorio de Salida" />
                    <RadzenTextBox @bind-Value="AppConfig.OutputDirectory" class="rz-w-100" />
                </RadzenColumn>
            </RadzenRow>
            
            <RadzenRow Gap="1rem" class="rz-mb-4">
                <RadzenColumn Size="6">
                    <RadzenLabel Text="Directorio de Logs" />
                    <RadzenTextBox @bind-Value="AppConfig.LogDirectory" class="rz-w-100" />
                </RadzenColumn>
                <RadzenColumn Size="6">
                    <RadzenLabel Text="Nivel de Log" />
                    <RadzenTextBox @bind-Value="AppConfig.LogLevelFile" class="rz-w-100" />
                </RadzenColumn>
            </RadzenRow>
            
            <RadzenRow Gap="1rem" class="rz-mb-4">
                <RadzenColumn Size="6">
                    <RadzenLabel Text="Timeout OCR (segundos)" />
                    <RadzenNumeric @bind-Value="AppConfig.OcrTimeoutSeconds" class="rz-w-100" />
                </RadzenColumn>
                <RadzenColumn Size="6">
                    <RadzenLabel Text="Timeout Traducción (segundos)" />
                    <RadzenNumeric @bind-Value="AppConfig.TranslationTimeoutSeconds" class="rz-w-100" />
                </RadzenColumn>
            </RadzenRow>

            <RadzenButton ButtonType="ButtonType.Submit" Text="Guardar Configuración" Icon="save" ButtonStyle="ButtonStyle.Primary" />
        </RadzenTemplateForm>
    </div>
</RadzenCard>

@if(!string.IsNullOrEmpty(saveMessage))
{
    <RadzenAlert AlertStyle="AlertStyle.Success" AllowClose="false" class="rz-mt-4">
        @saveMessage
    </RadzenAlert>
}

@code {
    string saveMessage = "";

    async Task SaveConfig(PolyglotCLI.AppConfig args)
    {
        args.Save();
        PolyglotCLI.AppLogger.Initialize(args); // Reinitialize logger with new config
        saveMessage = "Configuración guardada exitosamente.";
        StateHasChanged();
        
        await Task.Delay(3000);
        saveMessage = "";
        StateHasChanged();
    }
}
