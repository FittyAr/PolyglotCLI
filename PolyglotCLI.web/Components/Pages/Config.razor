@page "/config"

<PageTitle>Configuración - PolyglotCLI</PageTitle>

<RadzenCard class="rz-my-4">
    <RadzenText TextStyle="TextStyle.H4" class="rz-mb-4">Configuración de la Aplicación</RadzenText>
    
    <RadzenTemplateForm Data="@AppConfig" Submit="@(async (PolyglotCLI.AppConfig args) => await SaveConfig(args))">
        <RadzenTabs>
            <Tabs>
                <!-- Pestaña 1: General -->
                <RadzenTabsItem Text="General" Icon="settings">
                    <GeneralConfigTab AppConfig="@AppConfig" IsTestingConnection="@isTestingConnection" OnTestConnection="@TestConnection" />
                </RadzenTabsItem>

                <!-- Pestaña 2: OCR Process -->
                <RadzenTabsItem Text="OCR Process" Icon="visibility">
                    <OcrConfigTab AppConfig="@AppConfig" AvailableModels="@availableModels" IsTestingConnection="@isTestingConnection" OnLoadModels="@LoadModelsFromServer" />
                </RadzenTabsItem>

                <!-- Pestaña 3: Translation -->
                <RadzenTabsItem Text="Translation" Icon="translate">
                    <TranslationConfigTab AppConfig="@AppConfig" AvailableModels="@availableModels" IsTestingConnection="@isTestingConnection" OnLoadModels="@LoadModelsFromServer" />
                </RadzenTabsItem>

                <!-- Pestaña 4: Revision -->
                <RadzenTabsItem Text="Revision" Icon="rate_review">
                    <RevisionConfigTab AppConfig="@AppConfig" AvailableModels="@availableModels" IsTestingConnection="@isTestingConnection" OnLoadModels="@LoadModelsFromServer" />
                </RadzenTabsItem>

                <!-- Pestaña 5: Output Formats -->
                <RadzenTabsItem Text="Output Formats" Icon="rule">
                    <OutputConfigTab AppConfig="@AppConfig" OutputFormatOptions="@outputFormatOptions" @bind-OutputFormatsInput="outputFormatsInput" @bind-InputExtensionsInput="inputExtensionsInput" />
                </RadzenTabsItem>

                <!-- Pestaña 6: Prompts del Sistema -->
                <RadzenTabsItem Text="Prompts del Sistema" Icon="description">
                    <PromptsConfigTab @bind-OcrPromptText="ocrPromptText" @bind-TranslationPromptText="translationPromptText" @bind-ReviewPromptText="reviewPromptText" @bind-PromptImproverPromptText="promptImproverPromptText" />
                </RadzenTabsItem>
            </Tabs>
        </RadzenTabs>

        <RadzenRow class="rz-mt-6">
            <RadzenColumn Size="12" class="rz-text-align-right">
                <RadzenButton ButtonType="ButtonType.Submit" Text="Guardar Configuración" Icon="save" ButtonStyle="ButtonStyle.Primary" />
            </RadzenColumn>
        </RadzenRow>
    </RadzenTemplateForm>
</RadzenCard>

@if(!string.IsNullOrEmpty(saveMessage))
{
    <RadzenAlert AlertStyle="AlertStyle.Success" AllowClose="false" class="rz-mt-4">
        @saveMessage
    </RadzenAlert>
}
