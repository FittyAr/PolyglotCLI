@page "/history"
@using PolyglotCLI
@using System.IO
@inject PolyglotCLI.AppConfig Config
@inject NavigationManager NavigationManager
@inject DialogService DialogService

<PageTitle>Historial de Trabajos - PolyglotCLI</PageTitle>

<RadzenText TextStyle="TextStyle.H4" class="rz-mb-4">Historial de Trabajos</RadzenText>

<RadzenDataGrid Data="@manifests" TItem="JobManifest" AllowFiltering="true" FilterMode="FilterMode.Simple" AllowPaging="true" PageSize="10" AllowSorting="true" class="rz-mb-4">
    <Columns>
        <RadzenDataGridColumn TItem="JobManifest" Property="JobId" Title="ID Trabajo" Width="180px" />
        <RadzenDataGridColumn TItem="JobManifest" Property="Status" Title="Estado" Width="120px">
            <Template Context="job">
                <RadzenBadge BadgeStyle="@GetBadgeStyle(job.Status)" Text="@job.Status" />
            </Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn TItem="JobManifest" Property="CreatedAt" Title="Fecha" FormatString="{0:d/M/yyyy HH:mm}" Width="150px" />
        <RadzenDataGridColumn TItem="JobManifest" Property="ModelName" Title="Modelo" Width="150px" />
        <RadzenDataGridColumn TItem="JobManifest" Title="Acciones" Width="220px" Filterable="false" Sortable="false">
            <Template Context="job">
                <RadzenButton Icon="list" ButtonStyle="ButtonStyle.Info" Size="ButtonSize.Small" class="rz-mr-1" title="Ver Detalles del Trabajo" 
                              Click="@(() => ViewJobDetails(job))" />
                
                <RadzenButton Icon="play_arrow" ButtonStyle="ButtonStyle.Success" Size="ButtonSize.Small" class="rz-mr-1" title="Reanudar Trabajo" 
                              Disabled="@(job.Status == "Completed")" Click="@(() => ResumeJob(job))" />
                
                @if(job.Status == "Failed" || job.Status == "InProgress")
                {
                    <RadzenButton Icon="psychology" ButtonStyle="ButtonStyle.Secondary" Size="ButtonSize.Small" class="rz-mr-1" title="Análisis de Errores IA" 
                                  Click="@(() => AnalyzeErrors(job))" />
                }
            </Template>
        </RadzenDataGridColumn>
    </Columns>
</RadzenDataGrid>

@if (selectedManifest != null && analysisResult != null)
{
    <RadzenCard class="rz-mt-4">
        <RadzenText TextStyle="TextStyle.H6">Análisis de Errores - @selectedManifest.JobId</RadzenText>
        <div class="virtual-console">@((MarkupString)analysisResult.Replace("\n", "<br/>"))</div>
        <RadzenButton Text="Cerrar" class="rz-mt-2" Click="@(() => analysisResult = null)" />
    </RadzenCard>
}

@code {
    List<JobManifest> manifests = new List<JobManifest>();
    JobManifest? selectedManifest = null;
    string? analysisResult = null;

    protected override void OnInitialized()
    {
        LoadManifests();
    }

    private void LoadManifests()
    {
        manifests = JobManifestService.LoadPastJobs();
    }

    BadgeStyle GetBadgeStyle(string status)
    {
        return status switch {
            "Completed" => BadgeStyle.Success,
            "Failed" => BadgeStyle.Danger,
            "InProgress" => BadgeStyle.Warning,
            _ => BadgeStyle.Info
        };
    }

    void ResumeJob(JobManifest job)
    {
        NavigationManager.NavigateTo($"/?resumeJobId={job.JobId}");
    }

    async Task AnalyzeErrors(JobManifest job)
    {
        selectedManifest = job;
        analysisResult = "Analizando errores con IA... por favor espera.";
        StateHasChanged();

        try 
        {
            string combinedErrors = JobManifestService.BuildErrorSummary(job);

            if (string.IsNullOrWhiteSpace(combinedErrors))
            {
                analysisResult = "No se encontraron mensajes de error registrados en el manifiesto.";
                return;
            }
            
            var recommendation = await PromptHelperService.AnalyzeErrorsAsync(
                combinedErrors, 
                Config.ApiUrl, 
                Config.DefaultModel ?? "", 
                Config.TranslationTimeoutSeconds, 
                Config.Temperature
            );
            analysisResult = recommendation;
        }
        catch (Exception ex)
        {
            analysisResult = $"Error durante el análisis: {ex.Message}";
        }
        StateHasChanged();
    }

    async Task ViewJobDetails(JobManifest job)
    {
        await DialogService.OpenAsync<PolyglotCLI.web.Components.Dialogs.JobDetailsDialog>($"Detalles del Trabajo", new Dictionary<string, object?>
        {
            { "Job", job }
        }, new DialogOptions { Width = "900px", Height = "650px", Resizable = true, Draggable = true });
    }
}
